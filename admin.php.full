        <?php elseif ($tab === 'judge'): ?>
            <?php
            // 评测机管理面板数据准备
            $allRunners = getAllJudgeRunners(false);
            $judgeCfg = getJudgeConfig();
            $enabledLangsStr = $judgeCfg['enabled_languages'];
            $enabledSet = [];
            if (trim($enabledLangsStr) !== '') {
                foreach (explode(',', $enabledLangsStr) as $c) {
                    $enabledSet[trim($c)] = true;
                }
            }
            $allLangs = [
                'c' => 'C', 'csharp' => 'C#',
                'cpp11' => 'C++11', 'cpp11_o2' => 'C++11(O2)',
                'cpp14' => 'C++14', 'cpp14_o2' => 'C++14(O2)',
                'cpp23' => 'C++23', 'cpp23_o2' => 'C++23(O2)',
                'python3' => 'Python 3',
            ];
            $editRunner = null;
            if (isset($_GET['edit'])) {
                $editRunner = getJudgeRunnerById((int)$_GET['edit']);
            }
            // 轻量级统计：只读 DB，不触发 curl（避免 GitHub API 超时导致白屏）
            $judgeDiag = [
                'enabled_runners_count' => 0,
                'pending_count' => 0,
                'oldest_pending_age' => null,
                'curl_available' => function_exists('curl_init'),
                'trigger_message' => '',
            ];
            foreach ($allRunners as $r) {
                if ($r['enabled']) $judgeDiag['enabled_runners_count']++;
            }
            try {
                $cnt = (int)$db->query("SELECT COUNT(*) FROM problem_submissions WHERE status = 'pending'")->fetchColumn();
                $judgeDiag['pending_count'] = $cnt;
                if ($cnt > 0) {
                    $oldest = $db->query("SELECT TIMESTAMPDIFF(MINUTE, created_at, NOW()) AS age FROM problem_submissions WHERE status = 'pending' ORDER BY id ASC LIMIT 1")->fetchColumn();
                    $judgeDiag['oldest_pending_age'] = $oldest !== false ? (int)$oldest : null;
                }
            } catch (Throwable $e) {}

            function maskJudgeToken(?string $t): string {
                if (empty($t)) return '（未配置）';
                if (strlen($t) > 16) {
                    return substr($t, 0, 8) . str_repeat('*', strlen($t) - 12) . substr($t, -4) . '（留空保存则不修改）';
                }
                return str_repeat('*', strlen($t)) . '（留空保存则不修改）';
            }

            // 优先级标签颜色：1-99 绿、100-199 蓝、200+ 橙
            function judgePriorityClass(int $p): string {
                if ($p < 100) return 'judge-priority-1';
                if ($p < 200) return 'judge-priority-2';
                return 'judge-priority-3';
            }
            // 优先级语义文案
            function judgePriorityLabel(int $p): string {
                if ($p < 100) return '主';
                if ($p < 200) return '备';
                return '兜底';
            }
            // 相对时间格式化
            function judgeRelativeTime(?string $ts): string {
                if (empty($ts)) return '从未触发';
                $t = strtotime($ts);
                if ($t === false) return htmlspecialchars($ts);
                $diff = time() - $t;
                if ($diff < 60)   return '刚刚';
                if ($diff < 3600) return floor($diff/60) . ' 分钟前';
                if ($diff < 86400) return floor($diff/3600) . ' 小时前';
                if ($diff < 604800) return floor($diff/86400) . ' 天前';
                return date('m-d H:i', $t);
            }
            ?>

