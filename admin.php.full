if (!in_array($_adminButtonThemeRaw, $_adminButtonThemeAllowed, true)) $_adminButtonThemeRaw = 'default';
// 站点样式：注入到 body 的 data-site-style 属性（original 原样式 / luogu 仿洛谷样式）
$_adminSiteStyleRaw = $current['site_style'] ?? 'original';
if (!in_array($_adminSiteStyleRaw, ['original', 'luogu'], true)) $_adminSiteStyleRaw = 'original';
