                        $isPermanent = empty($ip['expires_at']);
                    ?>
                    <tr>
                        <td><?= htmlspecialchars($ip['ip']) ?></td>
                        <td><?= htmlspecialchars($ip['reason']) ?></td>
                        <td><?= htmlspecialchars($ip['admin_name']) ?></td>
                        <td><?= formatDateTime($ip['created_at']) ?></td>
                        <td>
                            <?php if ($isPermanent): ?>
                                <span style="color:#ef4444;">永久</span>
                            <?php elseif ($isExpired): ?>
                                <span style="color:#10b981;">已过期</span>
                            <?php else: ?>
                                <?= formatDateTime($ip['expires_at']) ?>
                            <?php endif; ?>
                        </td>
                        <td>
                            <?php if ($isPermanent): ?>
                                <span class="badge" style="background:#7f1d1d;">永久</span>
                            <?php elseif ($isExpired): ?>
                                <span class="badge" style="background:#065f46;">已过期</span>
                            <?php else: ?>
                                <span class="badge" style="background:#991b1b;">生效中</span>
                            <?php endif; ?>
                        </td>
                        <td>
                            <form method="POST" style="display:inline;">
                                <input type="hidden" name="admin_action" value="remove_banned_ip">
                                <input type="hidden" name="ip" value="<?= htmlspecialchars($ip['ip']) ?>">
                                <button type="submit" class="btn btn-sm btn-success">解封</button>
                            </form>
