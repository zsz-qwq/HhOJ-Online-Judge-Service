function renderAvatar($user, $size = 32) {
    $url = avatarUrl($user);
    $hasName = !empty($user['username'] ?? '');
    $style = 'width:' . $size . 'px;height:' . $size . 'px;border-radius:50%;object-fit:cover;flex-shrink:0;background:' . ($hasName ? '#cbd5e1' : '#94a3b8') . ';font-size:0;';
    return '<img src="' . $url . '" alt="" style="' . $style . '" loading="lazy" decoding="async">';
}
function getPageParam() {
    $p = isset($_GET['p']) ? (int)$_GET['p'] : 1;
    return max(1, $p);
}
function paginationHtml($currentPage, $totalPages, $baseUrl, $pageParam = 'p') {
    if ($totalPages <= 1) return '';
    $sep = strpos($baseUrl, '?') !== false ? '&' : '?';
    $html = '<div class="pagination">';
    if ($currentPage > 1) {
        $html .= '<a href="' . $baseUrl . $sep . $pageParam . '=' . ($currentPage - 1) . '" class="btn btn-sm btn-primary">上一页</a>';
    }
    $start = max(1, $currentPage - 2);
    $end = min($totalPages, $currentPage + 2);
    for ($i = $start; $i <= $end; $i++) {
        if ($i == $currentPage) {
            $html .= '<span class="btn btn-sm" style="background:var(--accent);color:#fff;">' . $i . '</span>';
        } else {
            $html .= '<a href="' . $baseUrl . $sep . $pageParam . '=' . $i . '" class="btn btn-sm">' . $i . '</a>';
        }
    }
    if ($currentPage < $totalPages) {
        $html .= '<a href="' . $baseUrl . $sep . $pageParam . '=' . ($currentPage + 1) . '" class="btn btn-sm btn-primary">下一页</a>';
    }
    $html .= '</div>';
    return $html;
}
function getLikeCount($postType, $postId) {
    $cacheKey = "likes_count_{$postType}_{$postId}";
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT COUNT(*) FROM post_likes WHERE post_type = ? AND post_id = ?");
        $stmt->execute([$postType, $postId]);
        return cacheSet($cacheKey, (int)$stmt->fetchColumn());
    } catch (PDOException $e) {
        error_log('[getLikeCount] failed: ' . $e->getMessage());
        return 0;
    }
}
function hasLiked($userId, $postType, $postId) {
    $cacheKey = "likes_user_{$userId}_{$postType}_{$postId}";
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT 1 FROM post_likes WHERE user_id = ? AND post_type = ? AND post_id = ?");
        $stmt->execute([$userId, $postType, $postId]);
        return cacheSet($cacheKey, $stmt->fetchColumn() > 0);
    } catch (PDOException $e) {
        error_log('[hasLiked] failed: ' . $e->getMessage());
        return false;
    }
}
function columnExists($table, $column) {
    $table = preg_replace('/[^a-zA-Z0-9_]/', '', $table);
    $column = preg_replace('/[^a-zA-Z0-9_]/', '', $column);
    if ($table === '' || $column === '') return false;
    $cacheKey = "col_exists_{$table}_{$column}";
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;
    $db = getDB();
    try {
        $stmt = $db->query("SHOW COLUMNS FROM `{$table}` LIKE '{$column}'");
        return cacheSet($cacheKey, $stmt->fetchColumn() !== false);
    } catch (PDOException $e) {
        error_log('[columnExists] failed: ' . $e->getMessage());
        return cacheSet($cacheKey, false);
    }
}
function tableExists($table) {
    $table = preg_replace('/[^a-zA-Z0-9_]/', '', $table);
    if ($table === '') return false;
    $cacheKey = "table_exists_{$table}";
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;
    $db = getDB();
    try {
        $stmt = $db->query("SHOW TABLES LIKE '{$table}'");
        return cacheSet($cacheKey, $stmt->fetchColumn() !== false);
    } catch (PDOException $e) {
        error_log('[tableExists] failed: ' . $e->getMessage());
        return cacheSet($cacheKey, false);
    }
}
function clearLikeCache($userId, $postType, $postId) {
    cacheClear("likes_count_{$postType}_{$postId}");
    cacheClear("likes_user_{$userId}_{$postType}_{$postId}");
}
function getFavoriteCount($targetType, $targetId) {
    $cacheKey = "fav_count_{$targetType}_{$targetId}";
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT COUNT(*) FROM favorites WHERE target_type = ? AND target_id = ?");
        $stmt->execute([$targetType, $targetId]);
        return cacheSet($cacheKey, (int)$stmt->fetchColumn());
    } catch (PDOException $e) {
        error_log('[getFavoriteCount] failed: ' . $e->getMessage());
        return 0;
    }
}
function hasFavorited($userId, $targetType, $targetId) {
    $cacheKey = "fav_user_{$userId}_{$targetType}_{$targetId}";
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT 1 FROM favorites WHERE user_id = ? AND target_type = ? AND target_id = ?");
        $stmt->execute([$userId, $targetType, $targetId]);
        return cacheSet($cacheKey, $stmt->fetchColumn() > 0);
    } catch (PDOException $e) {
        error_log('[hasFavorited] failed: ' . $e->getMessage());
        return false;
    }
}
function toggleFavorite($userId, $targetType, $targetId) {
    cacheClear("fav_count_{$targetType}_{$targetId}");
    cacheClear("fav_user_{$userId}_{$targetType}_{$targetId}");
    $db = getDB();
    try {
        if (hasFavorited($userId, $targetType, $targetId)) {
            $stmt = $db->prepare("DELETE FROM favorites WHERE user_id = ? AND target_type = ? AND target_id = ?");
            $stmt->execute([$userId, $targetType, $targetId]);
            return ['status' => 'removed', 'favorited' => false];
        }
        $stmt = $db->prepare("INSERT INTO favorites (user_id, target_type, target_id) VALUES (?, ?, ?)");
        $stmt->execute([$userId, $targetType, $targetId]);
        return ['status' => 'added', 'favorited' => true];
    } catch (PDOException $e) {
        // 表结构异常时自动修复并重试一次
        ensureFavoritesTable();
        try {
            if (hasFavorited($userId, $targetType, $targetId)) {
                $stmt = $db->prepare("DELETE FROM favorites WHERE user_id = ? AND target_type = ? AND target_id = ?");
                $stmt->execute([$userId, $targetType, $targetId]);
                return ['status' => 'removed', 'favorited' => false];
            }
            $stmt = $db->prepare("INSERT INTO favorites (user_id, target_type, target_id) VALUES (?, ?, ?)");
            $stmt->execute([$userId, $targetType, $targetId]);
            return ['status' => 'added', 'favorited' => true];
        } catch (PDOException $e2) {
            error_log('[toggleFavorite] failed: ' . $e2->getMessage());
            return ['status' => 'error', 'message' => '操作失败，请稍后重试', 'favorited' => false];
        }
    }
}

// 确保 favorites 表结构正确
function ensureFavoritesTable() {
    $db = getDB();
    try {
        $stmt = $db->query("SHOW COLUMNS FROM favorites");
        $cols = $stmt->fetchAll(PDO::FETCH_COLUMN);
        $cols = array_map('strtolower', $cols);
        if (!in_array('target_type', $cols, true) || !in_array('target_id', $cols, true)) {
            $db->exec("DROP TABLE IF EXISTS favorites");
            $db->exec("CREATE TABLE favorites (
                id INT AUTO_INCREMENT PRIMARY KEY,
                user_id INT NOT NULL,
                target_type VARCHAR(20) NOT NULL,
                target_id INT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                INDEX idx_user_id (user_id),
                INDEX idx_target (target_type, target_id),
                UNIQUE KEY uk_favorite (user_id, target_type, target_id)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci");
        }
    } catch (PDOException $e) {
        try {
            $db->exec("CREATE TABLE IF NOT EXISTS favorites (
                id INT AUTO_INCREMENT PRIMARY KEY,
                user_id INT NOT NULL,
                target_type VARCHAR(20) NOT NULL,
                target_id INT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                INDEX idx_user_id (user_id),
                INDEX idx_target (target_type, target_id),
                UNIQUE KEY uk_favorite (user_id, target_type, target_id)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci");
        } catch (PDOException $e2) {
            error_log('[ensureFavoritesTable] failed: ' . $e2->getMessage());
        }
    }
}

// 确保 post_likes 表结构正确
function ensurePostLikesTable() {
    $db = getDB();
    try {
        $stmt = $db->query("SHOW COLUMNS FROM post_likes");
        $cols = $stmt->fetchAll(PDO::FETCH_COLUMN);
        $cols = array_map('strtolower', $cols);
        if (!in_array('post_type', $cols, true) || !in_array('post_id', $cols, true)) {
            $db->exec("DROP TABLE IF EXISTS post_likes");
            $db->exec("CREATE TABLE post_likes (
                id INT AUTO_INCREMENT PRIMARY KEY,
                user_id INT NOT NULL,
                post_type VARCHAR(20) NOT NULL,
                post_id INT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                INDEX idx_user_id (user_id),
                INDEX idx_post (post_type, post_id),
                UNIQUE KEY uk_like (user_id, post_type, post_id)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci");
        }
    } catch (PDOException $e) {
        try {
            $db->exec("CREATE TABLE IF NOT EXISTS post_likes (
                id INT AUTO_INCREMENT PRIMARY KEY,
                user_id INT NOT NULL,
                post_type VARCHAR(20) NOT NULL,
                post_id INT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                INDEX idx_user_id (user_id),
                INDEX idx_post (post_type, post_id),
                UNIQUE KEY uk_like (user_id, post_type, post_id)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci");
        } catch (PDOException $e2) {
            error_log('[ensurePostLikesTable] failed: ' . $e2->getMessage());
        }
    }
}
function clearFavoriteCache($userId, $targetType, $targetId) {
    cacheClear("fav_count_{$targetType}_{$targetId}");
    cacheClear("fav_user_{$userId}_{$targetType}_{$targetId}");
}
// 一次性迁移历史 role 值：红名 → 普通用户；紫名 → 管理员
function migrateLegacyRoles() {
    $cacheKey = 'roles_migrated_v1';
    if (cacheGet($cacheKey)) return;
    $db = getDB();
    try {
        $db->exec("UPDATE users SET role = '普通用户' WHERE role = '红名'");
        $db->exec("UPDATE users SET role = '管理员' WHERE role = '紫名'");
        cacheSet($cacheKey, true);
    } catch (PDOException $e) {
        error_log('[migrateLegacyRoles] failed: ' . $e->getMessage());
    }
}
// 当前生效的全站公告
function getActiveAnnouncements($limit = 5) {
    $ck = 'announcements_' . (int)$limit;
    $v = cacheGet($ck);
    if ($v !== null) return $v;
    $db = getDB();
    try {
        // ATTR_EMULATE_PREPARES=false 模式下 LIMIT ? 必须用 bindValue(PARAM_INT)
        $stmt = $db->prepare("SELECT * FROM site_announcements WHERE is_active = 1 ORDER BY sort_order ASC, created_at DESC LIMIT ?");
        $stmt->bindValue(1, (int)$limit, PDO::PARAM_INT);
        $stmt->execute();
        $rows = $stmt->fetchAll(PDO::FETCH_ASSOC);
        cacheSet($ck, $rows, 60);
        return $rows;
    } catch (PDOException $e) {
        error_log('[getActiveAnnouncements] failed: ' . $e->getMessage());
        return [];
    }
}

function getUserFavorites($user_id, $limit = 50, $offset = 0) {
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT * FROM favorites WHERE user_id = ? ORDER BY created_at DESC LIMIT ? OFFSET ?");
        $stmt->bindValue(1, (int)$user_id, PDO::PARAM_INT);
        $stmt->bindValue(2, (int)$limit, PDO::PARAM_INT);
        $stmt->bindValue(3, (int)$offset, PDO::PARAM_INT);
        $stmt->execute();
        return $stmt->fetchAll(PDO::FETCH_ASSOC);
    } catch (PDOException $e) {
        error_log('[getUserFavorites] failed: ' . $e->getMessage());
        return [];
    }
}
function getFavoriteItemInfo($target_type, $target_id) {
    $db = getDB();
    $info = ['title' => '', 'author' => '', 'url' => '', 'type_label' => '', 'created_at' => ''];
    try {
        switch ($target_type) {
            case 'forum':
                $stmt = $db->prepare("SELECT p.*, u.username, u.nickname FROM forum_posts p LEFT JOIN users u ON p.user_id = u.id WHERE p.id = ?");
                $stmt->execute([$target_id]);
                $row = $stmt->fetch(PDO::FETCH_ASSOC);
                if ($row) {
                    $info['title'] = $row['title'];
                    $info['author'] = !empty($row['nickname']) ? $row['nickname'] : $row['username'];
                    $info['url'] = '/discuss/' . $target_id;
                    $info['type_label'] = '讨论区帖子';
                    $info['created_at'] = $row['created_at'];
                }
                break;
            case 'forum_reply':
                $stmt = $db->prepare("SELECT r.*, u.username, u.nickname, p.id as post_id, p.title as post_title FROM forum_replies r LEFT JOIN users u ON r.user_id = u.id JOIN forum_posts p ON r.post_id = p.id WHERE r.id = ?");
                $stmt->execute([$target_id]);
                $row = $stmt->fetch(PDO::FETCH_ASSOC);
                if ($row) {
                    $info['title'] = '回复：' . $row['post_title'];
                    $info['author'] = !empty($row['nickname']) ? $row['nickname'] : $row['username'];
                    $info['url'] = '/discuss/' . $row['post_id'];
                    $info['type_label'] = '讨论区回复';
                    $info['created_at'] = $row['created_at'];
                }
                break;
            case 'station':
                $stmt = $db->prepare("SELECT p.*, u.username, u.nickname FROM station_posts p LEFT JOIN users u ON p.user_id = u.id WHERE p.id = ?");
                $stmt->execute([$target_id]);
                $row = $stmt->fetch(PDO::FETCH_ASSOC);
                if ($row) {
                    $info['title'] = $row['title'];
                    $info['author'] = !empty($row['nickname']) ? $row['nickname'] : $row['username'];
                    $info['url'] = '/station/' . $target_id;
                    $info['type_label'] = '站务公告';
                    $info['created_at'] = $row['created_at'];
                }
                break;
            case 'station_reply':
                $stmt = $db->prepare("SELECT r.*, u.username, u.nickname, p.id as post_id, p.title as post_title FROM station_replies r LEFT JOIN users u ON r.user_id = u.id JOIN station_posts p ON r.post_id = p.id WHERE r.id = ?");
                $stmt->execute([$target_id]);
                $row = $stmt->fetch(PDO::FETCH_ASSOC);
                if ($row) {
                    $info['title'] = '回复：' . $row['post_title'];
                    $info['author'] = !empty($row['nickname']) ? $row['nickname'] : $row['username'];
                    $info['url'] = '/station/' . $row['post_id'];
                    $info['type_label'] = '站务回复';
                    $info['created_at'] = $row['created_at'];
                }
                break;
            case 'benben':
                $stmt = $db->prepare("SELECT b.*, u.username, u.nickname FROM benben_posts b LEFT JOIN users u ON b.user_id = u.id WHERE b.id = ?");
                $stmt->execute([$target_id]);
                $row = $stmt->fetch(PDO::FETCH_ASSOC);
                if ($row) {
                    $info['title'] = mb_substr(strip_tags(renderMarkdown($row['content'])), 0, 50);
                    $info['author'] = !empty($row['nickname']) ? $row['nickname'] : $row['username'];
                    $info['url'] = '/benben';
                    $info['type_label'] = '犇犇';
                    $info['created_at'] = $row['created_at'];
                }
                break;
            case 'benben_reply':
                $stmt = $db->prepare("SELECT r.*, u.username, u.nickname, b.id as post_id FROM benben_replies r LEFT JOIN users u ON r.user_id = u.id JOIN benben_posts b ON r.post_id = b.id WHERE r.id = ?");
                $stmt->execute([$target_id]);
                $row = $stmt->fetch(PDO::FETCH_ASSOC);
                if ($row) {
                    $info['title'] = mb_substr(strip_tags(renderMarkdown($row['content'])), 0, 50);
                    $info['author'] = !empty($row['nickname']) ? $row['nickname'] : $row['username'];
                    $info['url'] = '/benben';
                    $info['type_label'] = '犇犇回复';
                    $info['created_at'] = $row['created_at'];
                }
                break;
            case 'ticket':
                $stmt = $db->prepare("SELECT t.*, u.username, u.nickname FROM tickets t LEFT JOIN users u ON t.user_id = u.id WHERE t.id = ?");
                $stmt->execute([$target_id]);
                $row = $stmt->fetch(PDO::FETCH_ASSOC);
                if ($row) {
                    $info['title'] = $row['title'];
                    $info['author'] = !empty($row['nickname']) ? $row['nickname'] : ($row['username'] ?? '未知用户');
                    $info['url'] = '/ticket/' . $target_id;
                    $info['type_label'] = '工单';
                    $info['created_at'] = $row['created_at'];
                }
                break;
            case 'ticket_reply':
                $stmt = $db->prepare("SELECT r.*, u.username, u.nickname, t.id as ticket_id, t.title as ticket_title FROM ticket_replies r LEFT JOIN users u ON r.user_id = u.id JOIN tickets t ON r.ticket_id = t.id WHERE r.id = ?");
                $stmt->execute([$target_id]);
                $row = $stmt->fetch(PDO::FETCH_ASSOC);
                if ($row) {
                    $info['title'] = '回复：' . $row['ticket_title'];
                    $info['author'] = !empty($row['nickname']) ? $row['nickname'] : ($row['username'] ?? '系统');
                    $info['url'] = '/ticket/' . $row['ticket_id'];
                    $info['type_label'] = '工单回复';
                    $info['created_at'] = $row['created_at'];
                }
                break;
        }
    } catch (PDOException $e) {
        error_log('[getFavoriteItemInfo] failed: ' . $e->getMessage());
    }
    return $info;
}
function renderLikeFavoriteBar($user, $targetType, $targetId, $redirect, $compact = false) {
    $likeCount = getLikeCount($targetType, $targetId);
    $hasLiked = $user ? hasLiked($user['id'], $targetType, $targetId) : false;
    $favCount = getFavoriteCount($targetType, $targetId);
    $hasFaved = $user ? hasFavorited($user['id'], $targetType, $targetId) : false;
    $size = $compact ? 14 : 16;
    $html = '<div class="action-bar" style="display:inline-flex;align-items:center;gap:8px;">';
    $likeIcon = icon('heart', $size, 'like-icon');
    $html .= '<button type="button" class="like-btn ' . ($hasLiked ? 'liked' : '') . '" aria-label="点赞" onclick="submitLikeFavorite(this,\'like_post\',\'' . htmlspecialchars($targetType) . '\',' . (int)$targetId . ',\'' . htmlspecialchars($redirect) . '\')">' . $likeIcon . ' <span>' . $likeCount . '</span></button>';
    $favIcon = icon('star', $size, 'favorite-icon');
    $favClass = 'like-btn ' . ($hasFaved ? 'favorite-active' : '');
    $html .= '<button type="button" class="' . $favClass . '" aria-label="收藏" onclick="submitLikeFavorite(this,\'favorite_post\',\'' . htmlspecialchars($targetType) . '\',' . (int)$targetId . ',\'' . htmlspecialchars($redirect) . '\')">' . $favIcon . ' <span>' . $favCount . '</span></button>';
    $html .= '</div>';
    return $html;
}
// 显示名称：优先昵称，点击跳转用户主页，颜色与洛谷同步
function renderShowUsername($userRow) {
    $uid = $userRow['user_id'] ?? ($userRow['id'] ?? 0);
    $profileUrl = $uid > 0 ? '/user/' . (int)$uid : '';
    if (!empty($userRow['banned']) && $userRow['banned'] == 1) {
        $html = '<span style="color:var(--danger);font-weight:700;">封禁用户</span>';
        return $profileUrl ? '<a href="' . $profileUrl . '" class="user-link">' . $html . '</a>' : $html;
    }
    $color = getUserDisplayColor($userRow);
    $displayName = !empty($userRow['nickname']) ? $userRow['nickname'] : ($userRow['username'] ?? '未知用户');
    $usernameHtml = '<span style="color:' . $color . ';font-weight:700;">' . htmlspecialchars($displayName) . '</span>';
    $tag = htmlspecialchars(!empty($userRow['luogu_hook']) ? $userRow['luogu_hook'] : ($userRow['tag'] ?? ''));
    if ($tag !== '') {
        $usernameHtml .= ' <span class="custom-tag" style="color:' . $color . ';font-weight:700;">' . $tag . '</span>';
    }
    if ($profileUrl) {
        $usernameHtml = '<a href="' . $profileUrl . '" class="user-link" style="text-decoration:none;">' . $usernameHtml . '</a>';
    }
    return $usernameHtml;
}

// 显示名称（含用户名悬停提示）
function renderShowNameWithTooltip($userRow) {
    $uid = $userRow['user_id'] ?? ($userRow['id'] ?? 0);
    $profileUrl = $uid > 0 ? '/user/' . (int)$uid : '';
    if (!empty($userRow['banned']) && $userRow['banned'] == 1) {
        $html = '<span style="color:var(--danger);font-weight:700;">封禁用户</span>';
        return $profileUrl ? '<a href="' . $profileUrl . '" class="user-link">' . $html . '</a>' : $html;
    }
    $color = getUserDisplayColor($userRow);
    $displayName = !empty($userRow['nickname']) ? $userRow['nickname'] : ($userRow['username'] ?? '未知用户');
    $username = htmlspecialchars($userRow['username'] ?? '');
    $title = $username ? 'title="用户名：' . $username . '"' : '';
    $html = '<span style="color:' . $color . ';font-weight:700;cursor:default;" ' . $title . '>' . htmlspecialchars($displayName) . '</span>';
    $tag = htmlspecialchars(!empty($userRow['luogu_hook']) ? $userRow['luogu_hook'] : ($userRow['tag'] ?? ''));
    if ($tag !== '') {
        $html .= ' <span class="custom-tag" style="color:' . $color . ';font-weight:700;">' . $tag . '</span>';
    }
    if ($profileUrl) {
        $html = '<a href="' . $profileUrl . '" class="user-link" style="text-decoration:none;" ' . $title . '>' . $html . '</a>';
    }
    return $html;
}
// 用户状态
function isLoggedIn() {
    return isset($_SESSION['user_id']);
}
function getUserById($user_id) {
    $cacheKey = 'user_' . (int)$user_id;
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;
    $db = getDB();
    $stmt = $db->prepare("SELECT * FROM users WHERE id = ?");
    $stmt->execute([$user_id]);
    return cacheSet($cacheKey, $stmt->fetch(PDO::FETCH_ASSOC) ?: []);
}
function clearUserCache($user_id) {
    cacheClear('user_' . (int)$user_id);
}
function getCurrentUser() {
    if (!isLoggedIn()) return null;
    return getUserById($_SESSION['user_id']) ?: null;
}
function getUserRole($user_id) {
    $user = getUserById($user_id);
    return $user['role'] ?? '普通用户';
}
// 注：isAdmin / isStationAdmin / canEditTag / canDeleteContent / canManageContent
// 五级管理员判定函数已迁移至 admin_roles.php（基于 L0-L5 等级比较）

// 封禁过期自动检查：禁言 / 禁私信 / 禁专栏 / 账号封禁
function checkAndClearExpiredBans($user_id) {
    $db = getDB();
    $user = getUserById($user_id);
    if (!$user) return;
    $now = date('Y-m-d H:i:s');
    if ($user['banned'] && !empty($user['ban_expires_at']) && $user['ban_expires_at'] <= $now) {
        $db->prepare("UPDATE users SET banned = 0, ban_expires_at = NULL WHERE id = ?")->execute([$user_id]);
        clearUserCache($user_id);
    }
    if ($user['muted'] && !empty($user['mute_expires_at']) && $user['mute_expires_at'] <= $now) {
        $db->prepare("UPDATE users SET muted = 0, mute_expires_at = NULL WHERE id = ?")->execute([$user_id]);
        clearUserCache($user_id);
    }
    if ($user['private_banned'] && !empty($user['private_ban_expires_at']) && $user['private_ban_expires_at'] <= $now) {
        $db->prepare("UPDATE users SET private_banned = 0, private_ban_expires_at = NULL WHERE id = ?")->execute([$user_id]);
        clearUserCache($user_id);
    }
    if (isset($user['article_banned']) && $user['article_banned'] && !empty($user['article_ban_expires_at']) && $user['article_ban_expires_at'] <= $now) {
        $db->prepare("UPDATE users SET article_banned = 0, article_ban_expires_at = NULL WHERE id = ?")->execute([$user_id]);
        clearUserCache($user_id);
    }
}

function isBanned($user_id) {
    checkAndClearExpiredBans($user_id);
    $user = getUserById($user_id);
    return !empty($user['banned']);
}
function isMuted($user_id) {
    checkAndClearExpiredBans($user_id);
    $user = getUserById($user_id);
    return !empty($user['muted']);
}
function isPrivateBanned($user_id) {
    checkAndClearExpiredBans($user_id);
    $user = getUserById($user_id);
    return !empty($user['private_banned']);
}
function isArticleBanned($user_id) {
    checkAndClearExpiredBans($user_id);
    $user = getUserById($user_id);
    return !empty($user['article_banned']);
}
// 签到
function getUserCheckinStatus($user_id) {
    $db = getDB();
    $today = date('Y-m-d');
    $stmt = $db->prepare("SELECT * FROM checkin_records WHERE user_id = ? AND checkin_date = ?");
    $stmt->execute([$user_id, $today]);
    $todayRecord = $stmt->fetch(PDO::FETCH_ASSOC);
    $lastStmt = $db->prepare("SELECT streak, total_days, checkin_date FROM checkin_records WHERE user_id = ? ORDER BY checkin_date DESC LIMIT 1");
    $lastStmt->execute([$user_id]);
    $lastRecord = $lastStmt->fetch(PDO::FETCH_ASSOC);
    return [
        'checked_today' => !empty($todayRecord),
        'streak' => $lastRecord ? (int)$lastRecord['streak'] : 0,
        'total_days' => $lastRecord ? (int)$lastRecord['total_days'] : 0,
        'last_date' => $lastRecord ? $lastRecord['checkin_date'] : null,
    ];
}
function doCheckin($user_id) {
    $db = getDB();
    $today = date('Y-m-d');
    $status = getUserCheckinStatus($user_id);
    if ($status['checked_today']) {
        return ['success' => false, 'message' => '今日已签到'];
    }
    $streak = $status['streak'];
    $total = $status['total_days'];
    if ($status['last_date']) {
        $lastDate = $status['last_date'];
        $yesterday = date('Y-m-d', strtotime('-1 day'));
        if ($lastDate !== $yesterday && $lastDate !== $today) {
            // 断签：扣双倍
            $penalty = $streak * 2;
            $total = max(0, $total - $penalty);
            $streak = 0;
        }
    }
    $streak++;
    $total++;
    $db->prepare("INSERT INTO checkin_records (user_id, checkin_date, streak, total_days) VALUES (?, ?, ?, ?)")->execute([$user_id, $today, $streak, $total]);
    return ['success' => true, 'streak' => $streak, 'total_days' => $total];
}
