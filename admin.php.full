        <?php elseif ($tab === 'vote'): ?>
            <?php
            // 投票管理：列出所有投票，支持关闭/开启/删除（他人投票需 L2+）
            $allVotes = [];
            $voteError = false;
            try {
                $voteStmt = $db->query("SELECT v.*, u.username, u.nickname,
                    (SELECT COUNT(*) FROM vote_records r WHERE r.vote_id = v.id) AS vote_count
                    FROM votes v LEFT JOIN users u ON v.created_by = u.id
                    ORDER BY v.created_at DESC LIMIT 100");
                $allVotes = $voteStmt->fetchAll(PDO::FETCH_ASSOC);
            } catch (Throwable $e) {
                error_log('[admin vote] ' . $e->getMessage());
                $voteError = true;
            }
            $openCount = 0; $closedCount = 0;
            foreach ($allVotes as $vv) {
                if ($vv['status'] === 'open') $openCount++; else $closedCount++;
            }
            ?>
            <div class="card"><div class="card-title"><?= icon('star', 20) ?> 投票管理 <span style="font-size:13px;color:var(--text-muted);font-weight:400;">进行中 <?= $openCount ?> · 已关闭 <?= $closedCount ?> · 共 <?= count($allVotes) ?></span></div>
            <?php if ($voteError): ?>
                <div class="alert alert-error">数据加载失败，请稍后重试</div>
            <?php elseif (empty($allVotes)): ?>
                <p style="color:var(--text-muted);">暂无投票。</p>
            <?php else: ?>
                <table>
                    <thead><tr><th>ID</th><th>标题</th><th>发起人</th><th>状态</th><th>参与人数</th><th>创建时间</th><th>操作</th></tr></thead>
                    <tbody>
                    <?php foreach ($allVotes as $v): ?>
                        <?php $isOpen = ($v['status'] === 'open'); ?>
                        <tr>
                            <td><?= (int)$v['id'] ?></td>
                            <td class="truncate"><a href="/vote/<?= (int)$v['id'] ?>"><?= htmlspecialchars($v['title']) ?></a></td>
                            <td><?= htmlspecialchars($v['nickname'] ?: $v['username']) ?></td>
                            <td>
                                <?php if ($isOpen): ?>
                                    <span style="color:var(--success);">进行中</span>
                                <?php else: ?>
                                    <span style="color:var(--text-muted);">已关闭</span>
                                <?php endif; ?>
                            </td>
                            <td><?= (int)$v['vote_count'] ?></td>
                            <td><?= formatTime($v['created_at']) ?></td>
                            <td>
                                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                    <form method="POST" action="/vote" style="display:inline;" onsubmit="return confirm('确定<?= $isOpen ? '关闭' : '重新开启' ?>此投票？');">
                                        <input type="hidden" name="action" value="toggle_vote_status">
                                        <input type="hidden" name="vote_id" value="<?= (int)$v['id'] ?>">
                                        <button type="submit" class="btn btn-sm"><?= $isOpen ? '关闭' : '开启' ?></button>
                                    </form>
                                    <form method="POST" action="/vote" style="display:inline;" onsubmit="return confirm('确定删除此投票？此操作不可恢复。');">
                                        <input type="hidden" name="action" value="delete_vote">
                                        <input type="hidden" name="vote_id" value="<?= (int)$v['id'] ?>">
                                        <button type="submit" class="btn btn-sm btn-danger">删除</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            <?php endif; ?>
            </div>

