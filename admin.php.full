        <?php elseif ($tab === 'logs'): ?>
            <?php
            // 操作日志查询：支持按用户/IP/操作类型/目标过滤
            $logPage = max(1, (int)($_GET['p'] ?? 1));
            $logPerPage = 50;
            $logOffset = ($logPage - 1) * $logPerPage;
            $logWhere = [];
            $logParams = [];
            $logFilterUser = trim($_GET['user'] ?? '');
            $logFilterIp = trim($_GET['ip'] ?? '');
            $logFilterAction = trim($_GET['action'] ?? '');
            $logFilterStatus = trim($_GET['status'] ?? '');
            if ($logFilterUser !== '') {
                if (ctype_digit($logFilterUser)) {
                    $logWhere[] = 'user_id = ?';
                    $logParams[] = (int)$logFilterUser;
                } else {
                    $logWhere[] = 'username = ?';
                    $logParams[] = $logFilterUser;
                }
            }
            if ($logFilterIp !== '') {
                $logWhere[] = 'ip = ?';
                $logParams[] = $logFilterIp;
            }
            if ($logFilterAction !== '') {
                $logWhere[] = 'action = ?';
                $logParams[] = $logFilterAction;
            }
            if ($logFilterStatus === 'success' || $logFilterStatus === 'failed') {
                $logWhere[] = 'status = ?';
                $logParams[] = $logFilterStatus;
            }
            $logWhereSql = $logWhere ? ('WHERE ' . implode(' AND ', $logWhere)) : '';
            try {
                $logCountStmt = $db->prepare("SELECT COUNT(*) FROM operation_log {$logWhereSql}");
                $logCountStmt->execute($logParams);
                $logTotal = (int)$logCountStmt->fetchColumn();
                $logTotalPages = max(1, (int)ceil($logTotal / $logPerPage));
                $logPage = min($logPage, $logTotalPages);
                $logOffset = ($logPage - 1) * $logPerPage;
                $logStmt = $db->prepare("SELECT * FROM operation_log {$logWhereSql} ORDER BY id DESC LIMIT ? OFFSET ?");
                $i = 1;
                foreach ($logParams as $p) {
                    $logStmt->bindValue($i++, $p);
                }
                $logStmt->bindValue($i++, $logPerPage, PDO::PARAM_INT);
                $logStmt->bindValue($i++, $logOffset, PDO::PARAM_INT);
                $logStmt->execute();
                $logRows = $logStmt->fetchAll(PDO::FETCH_ASSOC);
            } catch (Throwable $e) {
                error_log('[admin/logs] 查询失败：' . $e->getMessage());
                $logRows = [];
                $logTotal = 0;
                $logTotalPages = 1;
            }
            // 收集所有出现过的 action（用于过滤下拉）
            try {
                $logActions = $db->query("SELECT DISTINCT action FROM operation_log ORDER BY action")->fetchAll(PDO::FETCH_COLUMN);
            } catch (Throwable $e) {
                $logActions = [];
            }
            ?>
            <div class="card">
                <div class="card-title">操作日志</div>
                <p style="color:var(--text-muted);font-size:13px;margin:0 0 12px;">记录全站写操作（登录/发帖/私信/管理操作等）的操作人、IP、目标。仅副站长及以上可查看，自动保留 90 天。</p>
                <form method="GET" action="/admin/logs" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;">
                    <input type="text" name="user" placeholder="用户名或ID" value="<?= htmlspecialchars($logFilterUser) ?>" style="flex:1;min-width:120px;">
                    <input type="text" name="ip" placeholder="IP 地址" value="<?= htmlspecialchars($logFilterIp) ?>" style="flex:1;min-width:120px;">
                    <select name="action" style="flex:1;min-width:120px;">
                        <option value="">全部操作</option>
                        <?php foreach ($logActions as $act): ?>
                            <option value="<?= htmlspecialchars($act) ?>" <?= $logFilterAction === $act ? 'selected' : '' ?>><?= htmlspecialchars($act) ?></option>
                        <?php endforeach; ?>
                    </select>
                    <select name="status" style="flex:1;min-width:100px;">
                        <option value="">全部状态</option>
                        <option value="success" <?= $logFilterStatus === 'success' ? 'selected' : '' ?>>成功</option>
                        <option value="failed" <?= $logFilterStatus === 'failed' ? 'selected' : '' ?>>失败</option>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">筛选</button>
                    <a href="/admin/logs" class="btn btn-sm">重置</a>
                </form>
                <?php if (empty($logRows)): ?>
                    <div style="padding:32px;text-align:center;color:var(--text-muted);">暂无日志记录</div>
                <?php else: ?>
                    <div style="overflow-x:auto;">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th style="width:140px;">时间</th>
                                    <th style="width:120px;">用户</th>
                                    <th style="width:130px;">IP</th>
                                    <th style="width:130px;">操作</th>
                                    <th style="width:100px;">目标类型</th>
                                    <th style="width:80px;">目标ID</th>
                                    <th>详情</th>
                                    <th style="width:70px;">状态</th>
                                </tr>
                            </thead>
                            <tbody>
                                <?php foreach ($logRows as $log): ?>
                                    <tr>
                                        <td style="font-size:12px;color:var(--text-muted);"><?= htmlspecialchars(formatDateTime($log['created_at'])) ?></td>
                                        <td>
                                            <?php if ($log['user_id']): ?>
                                                <a href="/user/<?= (int)$log['user_id'] ?>"><?= htmlspecialchars($log['username'] ?: ('#' . $log['user_id'])) ?></a>
                                            <?php else: ?>
                                                <span style="color:var(--text-muted);">未登录</span>
                                            <?php endif; ?>
                                        </td>
                                        <td style="font-family:monospace;font-size:12px;"><?= htmlspecialchars($log['ip']) ?></td>
                                        <td><span class="tag"><?= htmlspecialchars($log['action']) ?></span></td>
                                        <td><?= htmlspecialchars($log['target_type']) ?></td>
                                        <td style="font-family:monospace;"><?= htmlspecialchars($log['target_id']) ?></td>
                                        <td style="font-size:12px;word-break:break-all;max-width:300px;"><?= htmlspecialchars(mb_substr($log['detail'], 0, 200, 'UTF-8')) ?></td>
                                        <td>
                                            <?php if ($log['status'] === 'success'): ?>
                                                <span style="color:var(--success);font-size:12px;">成功</span>
                                            <?php else: ?>
                                                <span style="color:var(--danger);font-size:12px;">失败</span>
                                            <?php endif; ?>
                                        </td>
                                    </tr>
                                <?php endforeach; ?>
                            </tbody>
                        </table>
                    </div>
                    <?php if ($logTotalPages > 1): ?>
                        <div style="margin-top:16px;text-align:center;">
                            <?php for ($pg = 1; $pg <= $logTotalPages; $pg++): ?>
                                <?php
                                $logQueryParams = array_filter([
                                    'user' => $logFilterUser, 'ip' => $logFilterIp,
                                    'action' => $logFilterAction, 'status' => $logFilterStatus,
                                    'p' => $pg > 1 ? $pg : null,
                                ]);
                                $logPageUrl = '/admin/logs' . ($logQueryParams ? '?' . http_build_query($logQueryParams) : '');
                                ?>
                                <a href="<?= htmlspecialchars($logPageUrl) ?>" class="btn btn-sm <?= $pg === $logPage ? 'btn-primary' : '' ?>"><?= $pg ?></a>
                            <?php endfor; ?>
                        </div>
                    <?php endif; ?>
                    <div style="margin-top:12px;font-size:12px;color:var(--text-muted);text-align:center;">共 <?= $logTotal ?> 条记录，第 <?= $logPage ?>/<?= $logTotalPages ?> 页</div>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</div>
<script>
(function(){
    // CSRF Token 全局注入：419 自动重试 + 相对 URL 处理
    var token = <?= json_encode(generateCsrfToken()) ?>;
    function refreshCsrfToken(newToken){
        if(!newToken || typeof newToken !== 'string') return false;
        token = newToken;
        window.CSRF_TOKEN = newToken;
        return true;
    }
    window.refreshCsrfToken = refreshCsrfToken;
    if (!token) return;
    document.addEventListener('submit', function(e){
        var f = e.target;
        if (!f || f.tagName !== 'FORM') return;
        if (f.querySelector('input[name="csrf_token"]')) return;
        var i = document.createElement('input');
        i.type = 'hidden'; i.name = 'csrf_token'; i.value = token;
        f.appendChild(i);
    }, true);
    window.CSRF_TOKEN = token;
    if (window.fetch) {
        var origFetch = window.fetch;
        window.fetch = function(url, opts){
            opts = opts || {};
            var headers = opts.headers || {};
            var u = typeof url === 'string' ? url : (url && url.url ? url.url : '');
            // 相对 URL（如 'admin.php'）也算同源
            var isSameOrigin = !u || u.charAt(0) === '/' || u.indexOf(location.origin) === 0 || /^[a-z]+:\/\//i.test(u) === false;
            if (isSameOrigin) {
                if (headers instanceof Headers) {
                    if (!headers.has('X-CSRF-TOKEN')) headers.set('X-CSRF-TOKEN', token);
                } else {
                    if (!headers['X-CSRF-TOKEN'] && !headers['x-csrf-token']) headers['X-CSRF-TOKEN'] = token;
                    opts.headers = headers;
                }
            }
            return origFetch(url, opts).then(function(resp){
                // 419 自动刷新 token 并重试一次
                if (resp.status === 419 && !opts.__csrfRetried) {
                    return resp.json().catch(function(){ return null; }).then(function(j){
                        if (j && j.csrf_token && refreshCsrfToken(j.csrf_token)) {
                            var newOpts = Object.assign({}, opts, {__csrfRetried: true});
                            if (newOpts.body instanceof FormData) {
                                var oldFd = opts.body;
                                newOpts.body = new FormData();
                                if (oldFd && typeof oldFd.forEach === 'function') {
                                    oldFd.forEach(function(v, k){
                                        if (k === 'csrf_token') return;
                                        newOpts.body.append(k, v);
                                    });
                                }
                                newOpts.body.append('csrf_token', token);
                            }
                            return window.fetch(url, newOpts);
                        }
                        return resp;
                    });
                }
                return resp;
            });
        };
    }
    var origSend = XMLHttpRequest.prototype.send;
    var origOpen = XMLHttpRequest.prototype.open;
    XMLHttpRequest.prototype.open = function(method, url){
        this.__csrf_url = url;
        return origOpen.apply(this, arguments);
    };
    XMLHttpRequest.prototype.send = function(){
        try {
            var u = this.__csrf_url || '';
            if (!u || u.charAt(0) === '/' || u.indexOf(location.origin) === 0 || /^[a-z]+:\/\//i.test(u) === false) {
                this.setRequestHeader('X-CSRF-TOKEN', token);
            }
        } catch(e){}
        return origSend.apply(this, arguments);
    };
})();
</script>
</body>
</html>
