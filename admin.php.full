                    <label style="display:flex;align-items:center;gap:6px;font-size:14px;cursor:pointer;"><input type="checkbox" name="show_once" <?= !empty($editItem['show_once']) ? 'checked' : '' ?>> 关闭后不再显示（按浏览器）</label>
                    <div style="margin-left:auto;display:flex;gap:8px;">
