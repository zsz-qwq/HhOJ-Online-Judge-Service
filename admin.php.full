                <tbody>
                <?php
                $userModals = '';
                $matchDuration = function($expires_at) {
                    if (empty($expires_at)) return 0;
                    $remaining = strtotime($expires_at) - time();
                    $durations = [0, 3600, 21600, 86400, 259200, 604800, 2592000];
                    $closest = 0;
                    $minDiff = PHP_INT_MAX;
                    foreach ($durations as $d) {
                        $diff = abs($remaining - $d);
                        if ($diff < $minDiff) { $minDiff = $diff; $closest = $d; }
                    }
                    return $closest;
                };
                $durOptions = function($selected) {
                    $opts = '';
                    foreach ([0 => '永久', 3600 => '1小时', 21600 => '6小时', 86400 => '1天', 259200 => '3天', 604800 => '7天', 2592000 => '30天'] as $val => $label) {
                        $sel = ($val == $selected) ? ' selected' : '';
                        $opts .= '<option value="' . $val . '"' . $sel . '>' . $label . '</option>';
                    }
                    return $opts;
                };
                // 分页：30 个一页
                $userPage = isset($_GET['p']) ? max(1, (int)$_GET['p']) : 1;
                $userPerPage = 30;
                $userTotal = (int)$db->query("SELECT COUNT(*) FROM users")->fetchColumn();
                $userTotalPages = max(1, (int)ceil($userTotal / $userPerPage));
                $userPage = min($userPage, $userTotalPages);
                $userOffset = ($userPage - 1) * $userPerPage;
                // SQL 补充 luogu_color / avatar，使 renderShowUsername 的颜色与头像与主站一致外显
                // LIMIT/OFFSET 使用直接整数插值（已校验为 int，无注入风险），避免 PDO 在部分 MySQL 配置下 LIMIT ? 参数绑定异常导致仅返回一条记录
                $userStmt = $db->prepare("SELECT id, username, nickname, role, tag, luogu_hook, luogu_color, avatar, banned, muted, private_banned, article_banned, ban_expires_at, mute_expires_at, private_ban_expires_at, article_ban_expires_at, last_ip, last_activity, created_at FROM users ORDER BY id ASC LIMIT " . (int)$userPerPage . " OFFSET " . (int)$userOffset);
                $userStmt->execute();
                foreach ($userStmt->fetchAll() as $u):
                ?>
                    <tr>
                        <td><?= $u['id'] ?></td>
                        <td>
                            <div class="user-info">
                                <?= renderAvatar($u, 32) ?><?= renderShowUsername($u) ?>
                            </div>
                        </td>
                        <td><?= htmlspecialchars($u['role']) ?></td>
                        <td><?= htmlspecialchars((!empty($u['luogu_hook']) ? $u['luogu_hook'] : ($u['tag'] ?? ''))) ?></td>
                        <td>
                            <?php
                            if ($u['banned']) {
                                if ($u['ban_expires_at']) {
                                    echo '<span style="color:var(--danger)">封禁至 ' . date('m-d H:i', strtotime($u['ban_expires_at'])) . '</span>';
                                } else {
                                    echo '<span style="color:var(--danger)">已封禁(永久)</span>';
                                }
                            }
                            if ($u['muted']) {
                                if ($u['mute_expires_at']) {
                                    echo '<br><span style="color:var(--warning)">禁言至 ' . date('m-d H:i', strtotime($u['mute_expires_at'])) . '</span>';
                                } else {
                                    echo '<br><span style="color:var(--warning)">已禁言(永久)</span>';
                                }
                            }
                            if ($u['private_banned']) {
                                if ($u['private_ban_expires_at']) {
                                    echo '<br><span style="color:var(--warning)">禁私信至 ' . date('m-d H:i', strtotime($u['private_ban_expires_at'])) . '</span>';
                                } else {
                                    echo '<br><span style="color:var(--warning)">禁私信(永久)</span>';
                                }
                            }
                            if (!$u['banned'] && !$u['muted'] && !$u['private_banned']) echo '正常';
                            ?>
                        </td>
                        <td><?= htmlspecialchars($u['last_ip'] ?? '') ?></td>
                        <td>
                            <?php if (isUserOnline($u['id'])): ?>
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--success);margin-right:4px;"></span>在线
                            <?php else: ?>
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--text-muted);margin-right:4px;"></span>离线
                            <?php endif; ?>
                        </td>
                        <td><?= formatDateTime($u['created_at']) ?></td>
                        <td>
                            <?php
                            $target_role = $u['role'];
                            // 五级体系：可编辑资料（L3+）或可封禁（L2+）或可禁专栏（L1+）均显示操作按钮
                            $can_edit_user = canEditUser($u['id']);
                            $can_ban_user = canBanUser($u['id']);
                            $can_article_ban_user = canDisableUserArticle($u['id']);
                            $can_operate = $can_edit_user || $can_ban_user || $can_article_ban_user;
                            // 按钮文字：L3+「编辑」；L2「封禁」；L1「禁专栏」
                            $btn_text = $can_edit_user ? '编辑' : ($can_ban_user ? '封禁' : '禁专栏');
                            ?>
                            <?php if ($can_operate): ?>
                                <button type="button" class="btn btn-sm btn-primary" onclick="openUserModal(<?= $u['id'] ?>)"><?= $btn_text ?></button>
                            <?php else: ?>
                                <span style="color:var(--text-muted);font-size:12px;">不可操作</span>
                            <?php endif; ?>
                        </td>
                    </tr>
                <?php
                if ($can_operate) {
                    // 副站长及以上（L4+）可变更角色，下拉选项动态生成
                    $can_edit_role = (currentUserLevel() >= 4);
                    $modalId = $u['id'];
                    // 模态框标题：L3+「编辑用户」；L2「封禁用户」；L1「禁专栏用户」
                    $modal_title = $can_edit_user ? '编辑用户：' : ($can_ban_user ? '封禁用户：' : '禁专栏用户：');
                    $userModals .= '<div class="modal-overlay" id="user-modal-' . $modalId . '">
                        <div class="modal">
                            <div class="modal-title">' . $modal_title . htmlspecialchars($u['username']) . '<button type="button" class="modal-close" onclick="closeUserModal(' . $modalId . ')">&times;</button></div>
                            <form method="POST" class="modal-form">
                                <input type="hidden" name="admin_action" value="edit_user">
                                <input type="hidden" name="user_id" value="' . $modalId . '">
                                <label>用户名</label>
                                <div style="padding:8px 12px;background:var(--input-bg);border-radius:8px;color:var(--text-main);">' . htmlspecialchars($u['username']) . ' <span style="color:var(--text-muted);font-size:12px;">(不可修改)</span></div>';
                    // 资料编辑：仅大管理及以上（canEditUser）可见
                    if ($can_edit_user) {
                        $userModals .= '<label>昵称</label>
                                <input type="text" name="nickname" value="' . htmlspecialchars($u['nickname'] ?? '') . '">
                                <label>Tag</label>
                                <input type="text" name="tag" value="' . htmlspecialchars($u['tag'] ?? '') . '" maxlength="12">';
                        if ($can_edit_role) {
                            // 五级管理员体系：动态生成可选角色（含目标用户当前角色）
                            $assignableList = getAssignableRoles();
                            $roleOptions = '';
                            $allRoles = getAllRoles();
                            $assignableSet = array_flip($assignableList);
                            foreach ($allRoles as $r) {
                                $val = $r['value'];
                                $isCurrent = ($val === $u['role']);
                                $canAssign = isset($assignableSet[$val]);
                                if (!$canAssign && !$isCurrent) continue;
                                $selected = $isCurrent ? ' selected' : '';
                                $disabled = (!$canAssign && $isCurrent) ? ' disabled' : '';
                                $label = htmlspecialchars($val) . ($disabled ? '（当前角色，无权变更）' : '');
                                $roleOptions .= '<option value="' . htmlspecialchars($val) . '"' . $selected . $disabled . '>' . $label . '</option>';
                            }
                            $userModals .= '<label>角色</label>
                                <select name="role">' . $roleOptions . '</select>';
                        } else {
                            $userModals .= '<input type="hidden" name="role" value="' . htmlspecialchars($u['role']) . '">';
                        }
                    } else {
                        // 无资料编辑权限：以 hidden 传回原值，后端会再次用数据库原值兜底
                        $userModals .= '<input type="hidden" name="nickname" value="' . htmlspecialchars($u['nickname'] ?? '') . '">
                                <input type="hidden" name="tag" value="' . htmlspecialchars($u['tag'] ?? '') . '">
                                <input type="hidden" name="role" value="' . htmlspecialchars($u['role']) . '">';
                    }
                    // 封禁/禁言/禁私信：仅社区管理及以上（canBanUser）可见
                    if ($can_ban_user) {
                        $ban_dur_sel = ($u['banned'] && !empty($u['ban_expires_at'])) ? $matchDuration($u['ban_expires_at']) : 0;
                        $mute_dur_sel = ($u['muted'] && !empty($u['mute_expires_at'])) ? $matchDuration($u['mute_expires_at']) : 0;
                        $private_ban_dur_sel = ($u['private_banned'] && !empty($u['private_ban_expires_at'])) ? $matchDuration($u['private_ban_expires_at']) : 0;
                        $userModals .= '<div class="checkbox-row"><input type="checkbox" name="banned" id="banned-' . $modalId . '"' . ($u['banned'] ? ' checked' : '') . '><label for="banned-' . $modalId . '">封禁账号</label><select name="ban_duration" style="margin-left:8px;padding:4px 8px;border-radius:6px;border:1px solid var(--input-border);background:var(--input-bg);color:var(--text-main);font-size:13px;">' . $durOptions($ban_dur_sel) . '</select></div>
                            <div class="checkbox-row"><input type="checkbox" name="muted" id="muted-' . $modalId . '"' . ($u['muted'] ? ' checked' : '') . '><label for="muted-' . $modalId . '">禁言</label><select name="mute_duration" style="margin-left:8px;padding:4px 8px;border-radius:6px;border:1px solid var(--input-border);background:var(--input-bg);color:var(--text-main);font-size:13px;">' . $durOptions($mute_dur_sel) . '</select></div>
                            <div class="checkbox-row"><input type="checkbox" name="private_banned" id="private_banned-' . $modalId . '"' . ($u['private_banned'] ? ' checked' : '') . '><label for="private_banned-' . $modalId . '">禁止私信</label><select name="private_ban_duration" style="margin-left:8px;padding:4px 8px;border-radius:6px;border:1px solid var(--input-border);background:var(--input-bg);color:var(--text-main);font-size:13px;">' . $durOptions($private_ban_dur_sel) . '</select></div>';
                    } else {
                        // 无封禁权限：传回原值占位（后端会再次用数据库原值兜底）
                        $userModals .= '<input type="hidden" name="banned" value="' . ((int)($u['banned'] ?? 0)) . '">
                            <input type="hidden" name="muted" value="' . ((int)($u['muted'] ?? 0)) . '">
                            <input type="hidden" name="private_banned" value="' . ((int)($u['private_banned'] ?? 0)) . '">
                            <input type="hidden" name="ban_duration" value="0">
                            <input type="hidden" name="mute_duration" value="0">
                            <input type="hidden" name="private_ban_duration" value="0">';
                    }
                    // 禁专栏：专栏管理及以上（canDisableUserArticle）可见，与封禁独立
                    if ($can_article_ban_user) {
                        $article_ban_dur_sel = (!empty($u['article_banned']) && !empty($u['article_ban_expires_at'])) ? $matchDuration($u['article_ban_expires_at']) : 0;
                        $userModals .= '<div class="checkbox-row"><input type="checkbox" name="article_banned" id="article_banned-' . $modalId . '"' . (!empty($u['article_banned']) ? ' checked' : '') . '><label for="article_banned-' . $modalId . '">禁止专栏</label><select name="article_ban_duration" style="margin-left:8px;padding:4px 8px;border-radius:6px;border:1px solid var(--input-border);background:var(--input-bg);color:var(--text-main);font-size:13px;">' . $durOptions($article_ban_dur_sel) . '</select></div>';
                    } else {
                        $userModals .= '<input type="hidden" name="article_banned" value="' . ((int)($u['article_banned'] ?? 0)) . '">
                            <input type="hidden" name="article_ban_duration" value="0">';
                    }
                    $userModals .= '<label>变更理由（变更角色/封禁/禁言时必填）</label>
                        <textarea name="role_change_reason" rows="3" placeholder="请说明变更原因，将记录到陶片…" style="width:100%;padding:8px 12px;border:1px solid var(--input-border);border-radius:8px;background:var(--input-bg);color:var(--text-main);font-size:14px;box-sizing:border-box;resize:vertical;"></textarea>
                        <div class="modal-actions">
                            <button type="button" class="btn btn-outline" onclick="closeUserModal(' . $modalId . ')">取消</button>
                            <button type="submit" class="btn btn-primary">保存</button>
                        </div>
                    </form></div></div>';
                }
                endforeach;
                ?>
                </tbody>
            </table>
            <?php
            // 用户列表分页（保留当前 tab）
            if ($userTotalPages > 1) {
                $userBaseUrl = '/admin/users';
                $userSep = strpos($userBaseUrl, '?') !== false ? '&' : '?';
                echo '<div class="pagination" style="margin-top:16px;">';
                if ($userPage > 1) {
                    echo '<a href="' . $userBaseUrl . $userSep . 'p=' . ($userPage - 1) . '" class="btn btn-sm btn-primary">上一页</a>';
                }
                $start = max(1, $userPage - 2);
                $end = min($userTotalPages, $userPage + 2);
                for ($i = $start; $i <= $end; $i++) {
                    if ($i == $userPage) {
                        echo '<span class="btn btn-sm" style="background:var(--accent);color:#fff;">' . $i . '</span>';
                    } else {
                        echo '<a href="' . $userBaseUrl . $userSep . 'p=' . $i . '" class="btn btn-sm">' . $i . '</a>';
                    }
                }
                if ($userPage < $userTotalPages) {
                    echo '<a href="' . $userBaseUrl . $userSep . 'p=' . ($userPage + 1) . '" class="btn btn-sm btn-primary">下一页</a>';
                }
                echo '<span style="margin-left:auto;color:var(--text-muted);font-size:13px;align-self:center;">共 ' . $userTotal . ' 位用户 · 第 ' . $userPage . '/' . $userTotalPages . ' 页</span>';
                echo '</div>';
            }
            ?>
            <?= $userModals ?? '' ?>
            </div>

        <?php elseif ($tab === 'articles'): ?>
            <div class="card"><div class="card-title"><?= icon('book-open', 20) ?> 专栏审核</div>
            <?php
            $pendingArticles = [];
            $approvedArticles = [];
            $rejectedArticles = [];
            $disabledArticles = [];
            $articlesError = false;
            try {
                $pendingArticles = $db->query("SELECT a.*, u.username, u.nickname FROM articles a LEFT JOIN users u ON a.user_id = u.id WHERE a.status = 'pending' ORDER BY a.created_at DESC LIMIT 100")->fetchAll();
                $approvedArticles = $db->query("SELECT a.*, u.username, u.nickname FROM articles a LEFT JOIN users u ON a.user_id = u.id WHERE a.status = 'approved' ORDER BY a.created_at DESC LIMIT 50")->fetchAll();
                $rejectedArticles = $db->query("SELECT a.*, u.username, u.nickname FROM articles a LEFT JOIN users u ON a.user_id = u.id WHERE a.status = 'rejected' ORDER BY a.created_at DESC LIMIT 50")->fetchAll();
                $disabledArticles = $db->query("SELECT a.*, u.username, u.nickname FROM articles a LEFT JOIN users u ON a.user_id = u.id WHERE a.status = 'disabled' ORDER BY a.created_at DESC LIMIT 50")->fetchAll();
            } catch (Throwable $e) {
                error_log('[admin articles] ' . $e->getMessage());
                $articlesError = true;
            }
            ?>
            <?php if ($articlesError): ?>
                <div class="alert alert-error">数据加载失败，请稍后重试</div>
            <?php endif; ?>
            <h3 style="margin:16px 0 10px;color:var(--warning);">待审核（<?= count($pendingArticles) ?>）</h3>
            <?php if (empty($pendingArticles)): ?>
                <p style="color:var(--text-muted);">暂无待审核文章。</p>
            <?php else: ?>
                <table>
                    <thead><tr><th>ID</th><th>标题</th><th>作者</th><th>分类</th><th>时间</th><th>操作</th></tr></thead>
                    <tbody>
                    <?php foreach ($pendingArticles as $a): ?>
                        <tr>
                            <td><?= $a['id'] ?></td>
                            <td class="truncate"><a href="/article/<?= $a['id'] ?>"><?= htmlspecialchars($a['title']) ?></a></td>
                            <td><?= htmlspecialchars($a['nickname'] ?: $a['username']) ?></td>
                            <td><?= htmlspecialchars($a['type']) ?></td>
                            <td><?= formatTime($a['created_at']) ?></td>
                            <td>
                                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                    <button type="button" class="btn btn-sm btn-success" onclick="adminPost('review_article', {article_id:'<?= $a['id'] ?>', decision:'approve'}, '确定审核通过？')">通过</button>
                                    <button type="button" class="btn btn-sm btn-warning" onclick="adminPost('review_article', {article_id:'<?= $a['id'] ?>', decision:'reject'}, '确定拒绝？')">拒绝</button>
                                    <button type="button" class="btn btn-sm btn-danger" onclick="adminPost('delete_article', {article_id:'<?= $a['id'] ?>'}, '确定删除？')">删除</button>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            <?php endif; ?>

            <h3 style="margin:20px 0 10px;color:var(--success);">已通过（<?= count($approvedArticles) ?>）</h3>
            <?php if (empty($approvedArticles)): ?>
                <p style="color:var(--text-muted);">暂无已通过文章。</p>
            <?php else: ?>
                <table>
                    <thead><tr><th>ID</th><th>标题</th><th>作者</th><th>分类</th><th>时间</th><th>操作</th></tr></thead>
                    <tbody>
                    <?php foreach ($approvedArticles as $a): ?>
                        <tr>
                            <td><?= $a['id'] ?></td>
                            <td class="truncate"><a href="/article/<?= $a['id'] ?>"><?= htmlspecialchars($a['title']) ?></a></td>
                            <td><?= htmlspecialchars($a['nickname'] ?: $a['username']) ?></td>
                            <td><?= htmlspecialchars($a['type']) ?></td>
                            <td><?= formatTime($a['created_at']) ?></td>
                            <td>
                                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                    <button type="button" class="btn btn-sm btn-warning" onclick="adminPost('review_article', {article_id:'<?= $a['id'] ?>', decision:'disable'}, '确定禁用此文章？禁用后前台不可见。')">禁用</button>
                                    <button type="button" class="btn btn-sm btn-danger" onclick="adminPost('delete_article', {article_id:'<?= $a['id'] ?>'}, '确定删除？')">删除</button>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            <?php endif; ?>

            <h3 style="margin:20px 0 10px;color:var(--text-muted);">已禁用（<?= count($disabledArticles) ?>）</h3>
            <?php if (empty($disabledArticles)): ?>
                <p style="color:var(--text-muted);">暂无已禁用文章。</p>
            <?php else: ?>
                <table>
                    <thead><tr><th>ID</th><th>标题</th><th>作者</th><th>分类</th><th>时间</th><th>操作</th></tr></thead>
                    <tbody>
                    <?php foreach ($disabledArticles as $a): ?>
                        <tr>
                            <td><?= $a['id'] ?></td>
                            <td class="truncate"><a href="/article/<?= $a['id'] ?>"><?= htmlspecialchars($a['title']) ?></a></td>
                            <td><?= htmlspecialchars($a['nickname'] ?: $a['username']) ?></td>
                            <td><?= htmlspecialchars($a['type']) ?></td>
                            <td><?= formatTime($a['created_at']) ?></td>
                            <td>
                                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                    <button type="button" class="btn btn-sm btn-success" onclick="adminPost('review_article', {article_id:'<?= $a['id'] ?>', decision:'enable'}, '确定重新启用此文章？')">重新启用</button>
                                    <button type="button" class="btn btn-sm btn-danger" onclick="adminPost('delete_article', {article_id:'<?= $a['id'] ?>'}, '确定删除？')">删除</button>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            <?php endif; ?>

            <h3 style="margin:20px 0 10px;color:var(--danger);">已拒绝（<?= count($rejectedArticles) ?>）</h3>
            <?php if (empty($rejectedArticles)): ?>
                <p style="color:var(--text-muted);">暂无已拒绝文章。</p>
            <?php else: ?>
                <table>
                    <thead><tr><th>ID</th><th>标题</th><th>作者</th><th>分类</th><th>时间</th><th>操作</th></tr></thead>
                    <tbody>
                    <?php foreach ($rejectedArticles as $a): ?>
                        <tr>
                            <td><?= $a['id'] ?></td>
                            <td class="truncate"><a href="/article/<?= $a['id'] ?>"><?= htmlspecialchars($a['title']) ?></a></td>
                            <td><?= htmlspecialchars($a['nickname'] ?: $a['username']) ?></td>
                            <td><?= htmlspecialchars($a['type']) ?></td>
                            <td><?= formatTime($a['created_at']) ?></td>
                            <td>
                                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                    <button type="button" class="btn btn-sm btn-success" onclick="adminPost('review_article', {article_id:'<?= $a['id'] ?>', decision:'approve'}, '确定重新审核通过？')">重新通过</button>
                                    <button type="button" class="btn btn-sm btn-danger" onclick="adminPost('delete_article', {article_id:'<?= $a['id'] ?>'}, '确定删除？')">删除</button>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            <?php endif; ?>
            </div>

        <?php elseif ($tab === 'forum'): ?>
            <div class="card"><div class="card-title"><?= icon('forum', 20) ?> 讨论区管理</div>
            <form method="POST" onsubmit="return confirm('确定批量删除？');">
                <input type="hidden" name="admin_action" value="batch_delete">
                <input type="hidden" name="type" value="forum">
                <button type="submit" class="btn btn-danger btn-sm" style="margin-bottom:12px;">删除选中</button>
                <table>
                    <thead><tr><th><input type="checkbox" onclick="document.querySelectorAll('.cb-forum').forEach(c=>c.checked=this.checked)"></th><th>标题</th><th>作者</th><th>时间</th><th>操作</th></tr></thead>
                    <tbody>
                    <?php
                    $_forumRows = [];
                    try {
                        $_forumRows = $db->query("SELECT p.*, u.username, u.nickname FROM forum_posts p LEFT JOIN users u ON p.user_id = u.id ORDER BY p.created_at DESC LIMIT 100")->fetchAll();
                    } catch (Throwable $e) {
                        error_log('[admin forum] ' . $e->getMessage());
                        echo '<tr><td colspan="5" style="color:var(--danger);">数据加载失败，请稍后重试</td></tr>';
                    }
                    foreach ($_forumRows as $p):
                    ?>
