                        <span class="spacer"></span>
                        <span class="rules-counter" id="rules-counter">0 字</span>
                    </div>
                    <textarea name="content" id="rules-editor" class="rules-textarea" placeholder="在此输入社区规则（支持 Markdown）..." required><?= htmlspecialchars($rules['content'] ?? '') ?></textarea>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:16px;flex-wrap:wrap;">
                    <div style="font-size:12px;color:var(--text-muted);">提示：支持 Markdown 语法，下方可实时预览效果</div>
                    <div style="display:flex;gap:8px;">
                        <button type="button" class="btn btn-outline" onclick="rulesTogglePreview()">预览</button>
                        <button type="submit" class="btn btn-primary">保存规则</button>
