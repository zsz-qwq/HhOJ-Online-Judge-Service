// UI 下拉框使用的语言列表（不含旧别名）
// 若管理员设置了 judge_enabled_languages 则只展示启用子集
function getProblemLanguagesForUI(): array {
    $all = [
        'c'         => 'C',
        'csharp'    => 'C#',
        'cpp11'     => 'C++11',
        'cpp11_o2'  => 'C++11(O2)',
        'cpp14'     => 'C++14',
        'cpp14_o2'  => 'C++14(O2)',
        'cpp23'     => 'C++23',
        'cpp23_o2'  => 'C++23(O2)',
        'python3'   => 'Python 3',
    ];
    $enabled = getSetting('judge_enabled_languages', '');
    $enabled = trim((string)$enabled);
    if ($enabled === '') {
        return $all;
    }
    $enabledList = array_filter(array_map('trim', explode(',', $enabled)));
    if (empty($enabledList)) {
        return $all;
    }
    $result = [];
    foreach ($enabledList as $code) {
        if (isset($all[$code])) {
            $result[$code] = $all[$code];
        }
    }
    return empty($result) ? $all : $result;
}

// 规范化语言代码：旧别名映射到新代码
function normalizeLanguage(string $lang): string {
    $alias = [
        'cpp'    => 'cpp14',
        'python' => 'python3',
    ];
    return $alias[$lang] ?? $lang;
}

// 站点配置访问器（site_settings 表 key-value 读写）
$GLOBALS['_settings_cache'] = [];

// 读取站点配置项：DB > config.php 全局变量 > $default
function getSetting(string $key, $default = ''): string {
    if (array_key_exists($key, $GLOBALS['_settings_cache'])) {
        return $GLOBALS['_settings_cache'][$key];
    }
    $value = null;
    try {
        $db = getDB();
        $stmt = $db->prepare("SELECT setting_value FROM site_settings WHERE setting_key = ? LIMIT 1");
        $stmt->execute([$key]);
        $row = $stmt->fetch(PDO::FETCH_ASSOC);
        if ($row !== false) {
            $value = (string)$row['setting_value'];
        }
    } catch (Throwable $e) {
        error_log('[getSetting] ' . $key . ' failed: ' . $e->getMessage());
        $value = null;
    }
    // DB 无值时回退到 config.php 全局变量
    if ($value === null) {
        $fallbackMap = [
            'judge_github_token' => 'github_token',
            'judge_api_key'      => 'api_key',
        ];
        if (isset($fallbackMap[$key])) {
            $varName = $fallbackMap[$key];
            if (isset($GLOBALS[$varName])) {
                $value = (string)$GLOBALS[$varName];
            }
        }
    }
    if ($value === null) {
        $value = $default;
    }
    $GLOBALS['_settings_cache'][$key] = $value;
    return $value;
}

// 写入站点配置项（upsert）
function setSetting(string $key, string $value, $updatedBy = null): bool {
    try {
        $db = getDB();
        $stmt = $db->prepare(
            "INSERT INTO site_settings (setting_key, setting_value, updated_by, updated_at)
             VALUES (?, ?, ?, NOW())
             ON DUPLICATE KEY UPDATE setting_value = VALUES(setting_value), updated_by = VALUES(updated_by), updated_at = NOW()"
        );
        $ok = $stmt->execute([$key, $value, $updatedBy]);
        $GLOBALS['_settings_cache'][$key] = $value;
        return $ok;
    } catch (Throwable $e) {
        error_log('[setSetting] ' . $key . ' 写入失败：' . $e->getMessage());
        return false;
    }
}

// 获取评测机完整配置
function getJudgeConfig(): array {
    $config = [
        'github_token'    => '',
        'repo_owner'      => 'HhoJ-Dev',
        'repo_name'       => 'HhOJ-Online-Judge-Service',
        'workflow_id'     => 'judge.yml',
        'branch'          => 'main',
        'github_username' => '',
        'api_key'         => '',
        'enabled_languages' => '',
    ];
    try {
        $db = getDB();
        $stmt = $db->query("SELECT setting_key, setting_value FROM site_settings WHERE setting_key LIKE 'judge_%'");
        foreach ($stmt->fetchAll(PDO::FETCH_ASSOC) as $row) {
            $key = (string)$row['setting_key'];
            $val = (string)$row['setting_value'];
            switch ($key) {
                case 'judge_github_token':    $config['github_token'] = $val; break;
                case 'judge_repo_owner':      $config['repo_owner'] = $val ?: $config['repo_owner']; break;
                case 'judge_repo_name':       $config['repo_name'] = $val ?: $config['repo_name']; break;
                case 'judge_workflow_id':     $config['workflow_id'] = $val ?: $config['workflow_id']; break;
                case 'judge_branch':          $config['branch'] = $val ?: $config['branch']; break;
                case 'judge_github_username': $config['github_username'] = $val; break;
                case 'judge_api_key':         $config['api_key'] = $val; break;
                case 'judge_enabled_languages': $config['enabled_languages'] = $val; break;
            }
            $GLOBALS['_settings_cache'][$key] = $val;
        }
    } catch (Throwable $e) {
        error_log('[getJudgeConfig] failed: ' . $e->getMessage());
    }
    if ($config['github_token'] === '' && isset($GLOBALS['github_token'])) {
        $config['github_token'] = (string)$GLOBALS['github_token'];
    }
    if ($config['api_key'] === '' && isset($GLOBALS['api_key'])) {
        $config['api_key'] = (string)$GLOBALS['api_key'];
    }
    return $config;
}

// 测试 GitHub Token 是否能访问配置的仓库
function testJudgeConnection(): array {
    $cfg = getJudgeConfig();
    if (empty($cfg['github_token'])) {
        return ['success' => false, 'http_code' => 0, 'message' => '未配置 GitHub Token'];
    }
    if (!function_exists('curl_init')) {
        return ['success' => false, 'http_code' => 0, 'message' => '服务器未启用 cURL'];
    }
    $url = "https://api.github.com/repos/{$cfg['repo_owner']}/{$cfg['repo_name']}";
    $ch = curl_init($url);
    if ($ch === false) {
        return ['success' => false, 'http_code' => 0, 'message' => '无法初始化 cURL'];
    }
    curl_setopt_array($ch, [
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_HTTPHEADER => [
            'Accept: application/vnd.github.v3+json',
            'Authorization: token ' . $cfg['github_token'],
            'User-Agent: HhOJ-Test/1.0',
        ],
        CURLOPT_TIMEOUT => 15,
        CURLOPT_CONNECTTIMEOUT => 5,
        CURLOPT_SSL_VERIFYPEER => true,
    ]);
    $response = curl_exec($ch);
    $http_code = (int)curl_getinfo($ch, CURLINFO_HTTP_CODE);
    $curl_err = curl_error($ch);
    curl_close($ch);

    if ($http_code === 200) {
        return ['success' => true, 'http_code' => 200, 'message' => '连接成功，Token 可访问该仓库'];
    }
    $body = is_string($response) ? $response : '';
    $parsed = json_decode($body, true);
    $ghMsg = is_array($parsed) && isset($parsed['message']) ? (string)$parsed['message'] : '';
    $msg = "HTTP {$http_code}";
    if ($http_code === 0) {
        $msg = '网络请求失败：' . $curl_err;
    } elseif ($http_code === 404) {
        $msg = '仓库不存在或 Token 无权限访问（owner/repo 配置错误，或 Token 未对该仓库授权）';
    } elseif ($http_code === 401) {
        $msg = 'Token 无效（Bad credentials）';
    } elseif ($http_code === 403) {
        if (stripos($ghMsg, 'lifetime is greater than 366 days') !== false) {
            $msg = 'Token 被组织禁用（有效期超 366 天），需重新生成 ≤ 366 天的 fine-grained PAT';
        } else {
            $msg = 'Token 权限不足：' . $ghMsg;
        }
    } elseif ($ghMsg) {
        $msg .= '：' . $ghMsg;
    }
    return ['success' => false, 'http_code' => $http_code, 'message' => $msg];
}

// 触发评测机（调用 GitHub Actions 工作流）
// v5：从 judge_runners 表按 priority 升序读取所有 enabled 评测机，同 priority 多机随机选一个；
// 触发失败自动 fallback 到下一优先级组；表为空时回退到 getJudgeConfig() 单配置
function triggerJudge(?int $runnerId = null): array {
    if (!function_exists('curl_init')) {
        return ['success' => false, 'message' => '服务器未启用 cURL', 'reason' => 'no_curl', 'runner_id' => null, 'runner_name' => ''];
    }

    // 节流：5 秒内多次触发只发一次（批量提交场景）；指定 runnerId 时不节流
    static $lastTriggerTime = 0;
    $now = time();
    if ($runnerId === null && $now - $lastTriggerTime < 5) {
        return ['success' => true, 'message' => '评测任务已触发（节流合并）', 'reason' => 'throttled', 'runner_id' => null, 'runner_name' => ''];
    }

    $candidates = [];
    if ($runnerId !== null) {
        $runner = getJudgeRunnerById($runnerId);
        if ($runner === null) {
            return ['success' => false, 'message' => "评测机 #{$runnerId} 不存在", 'reason' => 'runner_not_found', 'runner_id' => $runnerId, 'runner_name' => ''];
        }
        if (!$runner['enabled']) {
            return ['success' => false, 'message' => "评测机「{$runner['name']}」已被禁用", 'reason' => 'runner_disabled', 'runner_id' => $runnerId, 'runner_name' => $runner['name']];
        }
        $candidates = [$runner];
    } else {
        $candidates = getEnabledJudgeRunners();
        if (empty($candidates)) {
            $cfg = getJudgeConfig();
            if (empty($cfg['github_token']) || empty($cfg['api_key'])) {
                return ['success' => false, 'message' => '评测服务未配置（请在后台 /admin 添加评测机）', 'reason' => 'config_missing', 'runner_id' => null, 'runner_name' => ''];
            }
            $candidates = [[
                'id' => 0, 'name' => '默认评测机(配置兼容)', 'priority' => 100, 'enabled' => 1,
                'owner' => $cfg['repo_owner'], 'repo' => $cfg['repo_name'],
                'workflow_id' => $cfg['workflow_id'], 'branch' => $cfg['branch'],
                'github_token' => $cfg['github_token'], 'api_key' => $cfg['api_key'],
            ]];
        }
    }

    // 按 priority 分组：同 priority 多机随机选一个，失败 fallback 到下一组
    $grouped = [];
    foreach ($candidates as $r) {
        $p = (int)$r['priority'];
        $grouped[$p][] = $r;
    }
    ksort($grouped);

    $lastError = '';
    $lastReason = '';
    foreach ($grouped as $priority => $runnersInGroup) {
        shuffle($runnersInGroup);
        foreach ($runnersInGroup as $runner) {
            $r = triggerSingleJudgeRunner($runner);
            if ($r['success']) {
                if ($runnerId === null) {
                    $lastTriggerTime = $now;
                }
                return $r;
            }
            $lastError = $r['message'];
            $lastReason = $r['reason'];
        }
    }

    return [
        'success' => false,
        'message' => $lastError ?: '所有评测机均触发失败',
        'reason'  => $lastReason ?: 'all_runners_failed',
        'runner_id' => null,
        'runner_name' => '',
    ];
}

// 触发单个评测机
function triggerSingleJudgeRunner(array $runner): array {
    $rid = (int)($runner['id'] ?? 0);
    $rname = (string)($runner['name'] ?? '');
    $token = (string)($runner['github_token'] ?? '');
    $apiKey = (string)($runner['api_key'] ?? '');

    if (empty($token) || empty($apiKey)) {
        return ['success' => false, 'message' => "评测机「{$rname}」未配置 Token 或 API Key", 'reason' => 'config_missing', 'runner_id' => $rid, 'runner_name' => $rname];
    }

    $owner = (string)($runner['owner'] ?? '');
    $repo  = (string)($runner['repo'] ?? '');
    $workflow_id = (string)($runner['workflow_id'] ?? 'judge.yml');
    $branch = (string)($runner['branch'] ?? 'main');

    $url = "https://api.github.com/repos/{$owner}/{$repo}/actions/workflows/{$workflow_id}/dispatches";
    $data = json_encode(['ref' => $branch]);

    $ch = curl_init($url);
    if ($ch === false) {
        return ['success' => false, 'message' => '无法初始化 cURL', 'reason' => 'curl_init_failed', 'runner_id' => $rid, 'runner_name' => $rname];
    }
    curl_setopt_array($ch, [
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_POST => true,
        CURLOPT_POSTFIELDS => $data,
        CURLOPT_HTTPHEADER => [
            'Accept: application/vnd.github.v3+json',
            'Authorization: token ' . $token,
            'Content-Type: application/json',
            'User-Agent: HhOJ-Trigger/1.0',
        ],
        CURLOPT_TIMEOUT => 15,
        CURLOPT_CONNECTTIMEOUT => 5,
        CURLOPT_SSL_VERIFYPEER => true,
    ]);

    $response = curl_exec($ch);
    $http_code = curl_getinfo($ch, CURLINFO_HTTP_CODE);
    $curl_err = curl_error($ch);
    curl_close($ch);

    if ($http_code === 204) {
        if ($rid > 0) {
            try {
                $db = getDB();
                $upd = $db->prepare("UPDATE judge_runners SET trigger_count = trigger_count + 1, last_triggered_at = NOW(), last_error = '', last_error_at = NULL WHERE id = ?");
                $upd->execute([$rid]);
            } catch (Throwable $ignore) {
                error_log('[triggerSingleJudgeRunner] update stats failed: ' . $ignore->getMessage());
            }
        }
        return ['success' => true, 'message' => "评测机「{$rname}」已触发", 'reason' => '', 'runner_id' => $rid, 'runner_name' => $rname];
    }

    $body = is_string($response) ? $response : '';
    $parsed = json_decode($body, true);
    $ghMessage = is_array($parsed) && isset($parsed['message']) ? (string)$parsed['message'] : '';
    error_log("[triggerJudge runner={$rname}({$rid})] HTTP={$http_code} curl_err={$curl_err} body={$body}");

    $error_msg = "评测机「{$rname}」触发失败 (HTTP {$http_code})";
    $reason = 'http_' . $http_code;
    if ($http_code === 0) {
        $error_msg = "评测机「{$rname}」网络请求失败：{$curl_err}";
        $reason = 'network';
    } elseif ($http_code === 404) {
        $error_msg .= '：仓库或工作流不存在（owner/repo/workflow 配置错误）';
        $reason = 'not_found';
    } elseif ($http_code === 401 || $http_code === 403) {
        if (stripos($ghMessage, 'lifetime is greater than 366 days') !== false) {
            $error_msg = "评测机「{$rname}」Token 被组织禁用（有效期超 366 天）";
            $reason = 'token_expired_org';
        } elseif (stripos($ghMessage, 'Bad credentials') !== false) {
            $error_msg = "评测机「{$rname}」Token 已失效或被撤销";
            $reason = 'token_invalid';
        } else {
            $error_msg .= '：Token 无权限（需 Actions: Write）';
            $reason = 'token_forbidden';
        }
    } elseif ($http_code === 422) {
        $error_msg .= '：工作流无法触发（分支不存在或被禁用）';
        $reason = 'workflow_disabled';
    }

    if ($rid > 0) {
        try {
            $db = getDB();
            $upd = $db->prepare("UPDATE judge_runners SET last_error = ?, last_error_at = NOW() WHERE id = ?");
            $upd->execute([mb_substr($error_msg, 0, 500, 'UTF-8'), $rid]);
        } catch (Throwable $ignore) {
            error_log('[triggerSingleJudgeRunner] update last_error failed: ' . $ignore->getMessage());
        }
    }

    return ['success' => false, 'message' => $error_msg, 'reason' => $reason, 'runner_id' => $rid, 'runner_name' => $rname];
}

// 收集所有有效的评测机 API Key（兼容 judge_runners 为空时回退到 site_settings / config.php）
function collectJudgeApiKeys(): array {
    $keys = [];
    try {
        $runners = getEnabledJudgeRunners();
        foreach ($runners as $r) {
            if (!empty($r['api_key'])) {
                $keys[] = (string)$r['api_key'];
            }
        }
    } catch (Throwable $e) {
        error_log('[collectJudgeApiKeys] failed: ' . $e->getMessage());
    }
    if (empty($keys)) {
        $cfg = getJudgeConfig();
        if (!empty($cfg['api_key'])) {
            $keys[] = $cfg['api_key'];
        }
        if (empty($keys) && isset($GLOBALS['api_key']) && $GLOBALS['api_key'] !== '') {
            $keys[] = (string)$GLOBALS['api_key'];
        }
    }
    return $keys;
}

// 验证评测机 API Key（时序安全比较）
function verifyJudgeApiKey(string $provided): bool {
    if ($provided === '') return false;
    foreach (collectJudgeApiKeys() as $validKey) {
        if (hash_equals($validKey, $provided)) {
            return true;
        }
    }
    return false;
}

// 从请求中提取评测机 API Key（X-API-Key 优先，回退 GET ?key）
function extractJudgeApiKeyFromRequest(): string {
    if (!empty($_SERVER['HTTP_X_API_KEY']) && is_string($_SERVER['HTTP_X_API_KEY'])) {
        return (string)$_SERVER['HTTP_X_API_KEY'];
    }
    if (isset($_GET['key']) && is_string($_GET['key'])) {
        return (string)$_GET['key'];
    }
    return '';
}

// 评测机注册表 CRUD
function getAllJudgeRunners(bool $onlyEnabled = false): array {
    try {
        $db = getDB();
        $sql = "SELECT id, name, priority, enabled, owner, repo, workflow_id, branch, github_token, github_username, api_key, last_triggered_at, last_error, last_error_at, trigger_count, created_at, updated_at FROM judge_runners";
        if ($onlyEnabled) $sql .= " WHERE enabled = 1";
        $sql .= " ORDER BY priority ASC, id ASC";
        $rows = $db->query($sql)->fetchAll(PDO::FETCH_ASSOC);
        foreach ($rows as &$r) {
            $r['id'] = (int)$r['id'];
            $r['priority'] = (int)$r['priority'];
            $r['enabled'] = (int)$r['enabled'];
            $r['trigger_count'] = (int)$r['trigger_count'];
        }
        return $rows;
    } catch (Throwable $e) {
        error_log('[getAllJudgeRunners] failed: ' . $e->getMessage());
        return [];
    }
}

function getEnabledJudgeRunners(): array {
    return getAllJudgeRunners(true);
}

function getJudgeRunnerById(int $id): ?array {
    if ($id <= 0) return null;
    try {
        $db = getDB();
        $stmt = $db->prepare("SELECT id, name, priority, enabled, owner, repo, workflow_id, branch, github_token, github_username, api_key, last_triggered_at, last_error, last_error_at, trigger_count, created_at, updated_at FROM judge_runners WHERE id = ?");
        $stmt->execute([$id]);
        $row = $stmt->fetch(PDO::FETCH_ASSOC);
        if (!$row) return null;
        $row['id'] = (int)$row['id'];
        $row['priority'] = (int)$row['priority'];
        $row['enabled'] = (int)$row['enabled'];
        $row['trigger_count'] = (int)$row['trigger_count'];
        return $row;
    } catch (Throwable $e) {
        error_log('[getJudgeRunnerById] failed: ' . $e->getMessage());
        return null;
    }
}

function addJudgeRunner(string $name, int $priority, bool $enabled, string $owner, string $repo,
                        string $workflowId, string $branch, string $githubToken, string $githubUsername,
                        string $apiKey, ?int $createdBy = null) {
    try {
        $db = getDB();
        $stmt = $db->prepare(
            "INSERT INTO judge_runners (name, priority, enabled, owner, repo, workflow_id, branch, github_token, github_username, api_key, created_at)
             VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, NOW())"
        );
        $ok = $stmt->execute([
            $name, $priority, $enabled ? 1 : 0, $owner, $repo, $workflowId, $branch,
            $githubToken, $githubUsername, $apiKey,
        ]);
        if (!$ok) return false;
        $newId = (int)$db->lastInsertId();
        if ($createdBy !== null) {
            logAdminAction('add_judge_runner', 'judge_runners', $newId, ['name' => $name, 'priority' => $priority, 'owner' => $owner, 'repo' => $repo], $createdBy);
        }
        return $newId;
    } catch (Throwable $e) {
        error_log('[addJudgeRunner] ' . $e->getMessage());
        return false;
    }
}

// 更新评测机（github_token / api_key 留空表示不修改）
function updateJudgeRunner(int $id, string $name, int $priority, bool $enabled, string $owner, string $repo,
                           string $workflowId, string $branch, string $githubToken, string $githubUsername,
                           string $apiKey, ?int $updatedBy = null): bool {
    try {
        $db = getDB();
        if ($githubToken !== '' && $apiKey !== '') {
            $stmt = $db->prepare(
                "UPDATE judge_runners SET name=?, priority=?, enabled=?, owner=?, repo=?, workflow_id=?, branch=?, github_token=?, github_username=?, api_key=? WHERE id=?"
            );
            $ok = $stmt->execute([$name, $priority, $enabled ? 1 : 0, $owner, $repo, $workflowId, $branch, $githubToken, $githubUsername, $apiKey, $id]);
        } elseif ($githubToken !== '' && $apiKey === '') {
            $stmt = $db->prepare(
                "UPDATE judge_runners SET name=?, priority=?, enabled=?, owner=?, repo=?, workflow_id=?, branch=?, github_token=?, github_username=? WHERE id=?"
            );
            $ok = $stmt->execute([$name, $priority, $enabled ? 1 : 0, $owner, $repo, $workflowId, $branch, $githubToken, $githubUsername, $id]);
        } elseif ($githubToken === '' && $apiKey !== '') {
            $stmt = $db->prepare(
                "UPDATE judge_runners SET name=?, priority=?, enabled=?, owner=?, repo=?, workflow_id=?, branch=?, github_username=?, api_key=? WHERE id=?"
            );
            $ok = $stmt->execute([$name, $priority, $enabled ? 1 : 0, $owner, $repo, $workflowId, $branch, $githubUsername, $apiKey, $id]);
        } else {
            $stmt = $db->prepare(
                "UPDATE judge_runners SET name=?, priority=?, enabled=?, owner=?, repo=?, workflow_id=?, branch=?, github_username=? WHERE id=?"
            );
            $ok = $stmt->execute([$name, $priority, $enabled ? 1 : 0, $owner, $repo, $workflowId, $branch, $githubUsername, $id]);
        }
        if ($ok && $updatedBy !== null) {
            logAdminAction('update_judge_runner', 'judge_runners', $id, ['name' => $name, 'priority' => $priority], $updatedBy);
        }
        return $ok;
    } catch (Throwable $e) {
        error_log('[updateJudgeRunner] ' . $e->getMessage());
        return false;
    }
}

function deleteJudgeRunner(int $id, ?int $deletedBy = null): bool {
    try {
        $db = getDB();
        $row = getJudgeRunnerById($id);
        $stmt = $db->prepare("DELETE FROM judge_runners WHERE id = ?");
        $ok = $stmt->execute([$id]);
        if ($ok && $deletedBy !== null && $row) {
            logAdminAction('delete_judge_runner', 'judge_runners', $id, ['name' => $row['name']], $deletedBy);
        }
        return $ok && $stmt->rowCount() > 0;
    } catch (Throwable $e) {
        error_log('[deleteJudgeRunner] ' . $e->getMessage());
        return false;
    }
}

// 评测机连接测试（指定 ID，不触发 workflow）
function testJudgeRunnerConnection(int $runnerId): array {
    $runner = getJudgeRunnerById($runnerId);
    if ($runner === null) {
        return ['success' => false, 'http_code' => 0, 'message' => "评测机 #{$runnerId} 不存在"];
    }
    if (empty($runner['github_token'])) {
        return ['success' => false, 'http_code' => 0, 'message' => "评测机「{$runner['name']}」未配置 Token"];
    }
    if (!function_exists('curl_init')) {
        return ['success' => false, 'http_code' => 0, 'message' => '服务器未启用 cURL'];
    }
    $url = "https://api.github.com/repos/{$runner['owner']}/{$runner['repo']}";
    $ch = curl_init($url);
    if ($ch === false) {
        return ['success' => false, 'http_code' => 0, 'message' => '无法初始化 cURL'];
    }
    curl_setopt_array($ch, [
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_HTTPHEADER => [
            'Accept: application/vnd.github.v3+json',
            'Authorization: token ' . $runner['github_token'],
            'User-Agent: HhOJ-Test/1.0',
        ],
        CURLOPT_TIMEOUT => 15,
        CURLOPT_CONNECTTIMEOUT => 5,
        CURLOPT_SSL_VERIFYPEER => true,
    ]);
    $response = curl_exec($ch);
    $http_code = (int)curl_getinfo($ch, CURLINFO_HTTP_CODE);
    $curl_err = curl_error($ch);
    curl_close($ch);

    $rname = $runner['name'];
    if ($http_code === 200) {
        return ['success' => true, 'http_code' => 200, 'message' => "评测机「{$rname}」连接成功，Token 可访问该仓库"];
    }
    $body = is_string($response) ? $response : '';
    $parsed = json_decode($body, true);
    $ghMsg = is_array($parsed) && isset($parsed['message']) ? (string)$parsed['message'] : '';
    $msg = "评测机「{$rname}」HTTP {$http_code}";
    if ($http_code === 0) {
        $msg = "评测机「{$rname}」网络请求失败：{$curl_err}";
    } elseif ($http_code === 404) {
        $msg = "评测机「{$rname}」仓库不存在或 Token 无权限";
    } elseif ($http_code === 401) {
        $msg = "评测机「{$rname}」Token 无效（Bad credentials）";
    } elseif ($http_code === 403) {
        if (stripos($ghMsg, 'lifetime is greater than 366 days') !== false) {
            $msg = "评测机「{$rname}」Token 被组织禁用（有效期超 366 天）";
        } else {
            $msg = "评测机「{$rname}」Token 权限不足：{$ghMsg}";
        }
    } elseif ($ghMsg) {
        $msg .= "：{$ghMsg}";
    }
    return ['success' => false, 'http_code' => $http_code, 'message' => $msg];
}

// 评测机连接诊断（管理员查看用）
function diagnoseJudgeService(): array {
    $cfg = getJudgeConfig();
    $allRunners = getAllJudgeRunners(false);
    $enabledRunners = array_filter($allRunners, function ($r) { return $r['enabled'] == 1; });
    $result = [
        'github_token_configured' => !empty($cfg['github_token']),
        'api_key_configured'      => !empty($cfg['api_key']),
        'curl_available'          => function_exists('curl_init'),
        'trigger_http_code'       => 0,
        'trigger_message'         => '',
        'pending_count'           => 0,
        'oldest_pending_age'      => null,
        'config'                  => $cfg,
        'runners'                 => $allRunners,
        'enabled_runners_count'   => count($enabledRunners),
    ];
    try {
        $db = getDB();
        $cnt = (int)$db->query("SELECT COUNT(*) FROM problem_submissions WHERE status = 'pending'")->fetchColumn();
        $result['pending_count'] = $cnt;
        if ($cnt > 0) {
            $oldest = $db->query("SELECT TIMESTAMPDIFF(MINUTE, created_at, NOW()) AS age FROM problem_submissions WHERE status = 'pending' ORDER BY id ASC LIMIT 1")->fetchColumn();
            $result['oldest_pending_age'] = $oldest !== false ? (int)$oldest : null;
        }
    } catch (Throwable $e) {
        error_log('[diagnoseJudgeService] failed: ' . $e->getMessage());
        $result['pending_count'] = -1;
    }
    $canTrigger = (count($enabledRunners) > 0) || ($result['github_token_configured'] && $result['api_key_configured']);
    if ($canTrigger && $result['curl_available']) {
        $r = triggerJudge();
        $result['trigger_message'] = $r['message'];
        $reasonMap = [
            'config_missing'      => '配置缺失',
            'no_curl'             => '无 cURL',
            'network'             => '网络失败',
            'not_found'           => '仓库/工作流不存在',
            'token_invalid'       => 'Token 失效',
            'token_expired_org'   => 'Token 被组织禁用（有效期超 366 天）',
            'token_forbidden'     => 'Token 无权限',
            'workflow_disabled'   => '工作流被禁用',
            'all_runners_failed'  => '所有评测机均失败',
        ];
        $result['trigger_http_code'] = $r['success'] ? 204 : ($reasonMap[$r['reason']] ?? $r['reason']);
    } else {
        $result['trigger_message'] = count($enabledRunners) === 0 ? '无启用的评测机' : '配置不完整，无法触发';
    }
    return $result;
}

// 重试触发所有 pending 提交的评测（评测机掉线后管理员手动恢复）
function retryPendingJudge(): array {
    $r = triggerJudge();
    if ($r['success']) {
        return ['triggered' => 1, 'failed' => 0, 'message' => '评测机已重新触发，pending 提交将在数秒内开始评测'];
    }
    return ['triggered' => 0, 'failed' => 1, 'message' => $r['message']];
}