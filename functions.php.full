// 今日运势
function getDailyFortune($user_id, $date) {
    $seed = crc32($user_id . $date);
    mt_srand($seed);
    $yi = ['写代码', '做题', '摸鱼', '重构', '写博客', '帮助他人', '学习新技能', '整理笔记', '调试程序', '优化性能'];
    $ji = ['熬夜', '删库', '和人对线', '拖延', '吃外卖', '裸考', '随意重构', '盲目自信', '跳过测试', '不经思考提交'];
    return [
        'yi' => $yi[mt_rand(0, count($yi) - 1)],
        'ji' => $ji[mt_rand(0, count($ji) - 1)],
    ];
}
// 忘记密码验证码
function generateResetCode() {
    $code = str_pad(random_int(0, 999999), 6, '0', STR_PAD_LEFT);
    $_SESSION['reset_code'] = $code;
    $_SESSION['reset_code_time'] = time();
    $_SESSION['reset_username'] = '';
    return $code;
}
// 颜色与徽章：五级管理员颜色映射（统一紫色名，仅深浅区分等级）
function getColorByRole($role) {
    $map = [
        '站长'     => '#6d28d9',
        '副站长'   => '#7c3aed',
        '大管理'   => '#8b5cf6',
        '社区管理' => '#9333ea',
        '专栏管理' => '#a855f7',
        '普通用户' => '#808080',
    ];
    return $map[$role] ?? '#808080';
}
// 用户显示颜色：管理员按级别配色；普通用户优先使用同步的洛谷颜色
function getUserDisplayColor($userRow) {
    if (empty($userRow)) return '#808080';
    $role = $userRow['role'] ?? '';
    if (roleLevel($role) >= 1) {
        return getColorByRole($role);
    }
    if (!empty($userRow['luogu_color'])) {
        $lc = strtolower(trim($userRow['luogu_color']));
        if ($lc === 'gray' || $lc === 'grey' || $lc === '#808080' || $lc === '#a0a0a0' || $lc === '#999') {
            return '#808080';
        }
        return htmlspecialchars($userRow['luogu_color']);
    }
    return '#808080';
}
function getRoleBadge($role) {
    $map = [
        '站长'     => ['label' => '站长',     'color' => '#6d28d9'],
        '副站长'   => ['label' => '副站长',   'color' => '#7c3aed'],
        '大管理'   => ['label' => '大管理',   'color' => '#8b5cf6'],
        '社区管理' => ['label' => '社区管理', 'color' => '#9333ea'],
        '专栏管理' => ['label' => '专栏管理', 'color' => '#a855f7'],
    ];
    return $map[$role] ?? null;
}
// Markdown / LaTeX 渲染（占位符保护代码块、行内代码、公式免被转义/格式化）
function renderMarkdown($text) {
    if (trim($text) === '') return '';

    // 请求级缓存：相同内容按 hash 缓存渲染结果
    $mdCacheKey = 'md_' . md5($text);
    $cached = cacheGet($mdCacheKey);
    if ($cached !== null) return $cached;

    $text = str_replace(["\r\n", "\r"], "\n", $text);
    // 统一去除行尾空白（保留硬换行的两个空格会在下面单独处理）
    // 修复：原代码未处理 \t，导致 tab 缩进列表识别失败
    $text = preg_replace('/\t/', '    ', $text);

    $placeholders = [];
    $placeholderIndex = 0;
    $addPlaceholder = function ($html) use (&$placeholders, &$placeholderIndex) {
        $key = '<!--MDPLACE' . ($placeholderIndex++) . '-->';
        $placeholders[$key] = $html;
        return $key;
    };

    // 1. 保护代码块 ```lang\ncode\n```
    //    必须先于行内代码处理（否则 ``` 会被当作三个反引号行内代码）
    //    修复：严格匹配 ``` 开头，结尾的 ``` 必须在行首或行尾（前面不能跟其他字符）
    $text = preg_replace_callback('/```([a-zA-Z0-9_+-]*)[ \t]*\n(.*?)```(?:[ \t]*\n|$)/s', function ($m) use ($addPlaceholder) {
        $lang = trim($m[1] ?? '');
        $code = $m[2];
        // 去除代码块尾部多余空行
        $code = preg_replace('/\n+$/', '', $code);
        $code = preg_replace('/^\n+/', '', $code);
        $langEsc = htmlspecialchars($lang, ENT_QUOTES, 'UTF-8');
        $cls = $lang ? 'language-' . $lang : '';
        $codeEsc = htmlspecialchars($code, ENT_QUOTES, 'UTF-8');
        $lineCount = substr_count($codeEsc, "\n") + 1;
        $lineNumbers = implode("\n", range(1, $lineCount));
        return $addPlaceholder('<pre class="code-block"><span class="code-line-numbers">' . $lineNumbers . '</span><code class="' . $cls . '">' . $codeEsc . '</code></pre>');
    }, $text);

    // 2. 保护行内代码 `code`（支持 ``code with ` inside``）
    //    修复：双反引号优先（允许内部含单反引号），单反引号兜底
    //    双反引号 ``...`` — 内容可含单反引号 `（但不含双反引号 ``）
    $text = preg_replace_callback('/``((?:[^`]|`[^`])+)``/s', function ($m) use ($addPlaceholder) {
        $code = $m[1];
        if (strlen($code) > 2 && $code[0] === ' ' && $code[strlen($code)-1] === ' ') {
            $code = substr($code, 1, -1);
        }
        return $addPlaceholder('<code>' . htmlspecialchars($code, ENT_QUOTES, 'UTF-8') . '</code>');
    }, $text);
    // 兜底：单反引号行内代码 `code`（最常见的场景）
    $text = preg_replace_callback('/`([^`\n]+)`/', function ($m) use ($addPlaceholder) {
        return $addPlaceholder('<code>' . htmlspecialchars($m[1], ENT_QUOTES, 'UTF-8') . '</code>');
    }, $text);

    // 3. 保护行间公式 $$...$$
    //    修复：旧正则非贪婪 `.+?` 在嵌套公式时会过早结束；改用更宽容的匹配
    $text = preg_replace_callback('/\$\$([\s\S]+?)\$\$(?!\$)/', function ($m) use ($addPlaceholder) {
        $inner = $m[1];
        // 不做 htmlspecialchars：KaTeX 自己会转义；保留原始公式字符
        return $addPlaceholder('<span class="math-display">$$' . $inner . '$$</span>');
    }, $text);

    // 4. 保护行内公式 $...$
    //    修复：旧正则要求 `[a-zA-Z\\\\=+\-^_]` 才视为公式，导致 \frac、\sum 等开头公式被吞；
    //          新规则：包含反斜杠命令、或含数字+运算符、或含下标上标 _ ^
    $text = preg_replace_callback('/(?<![\\$a-zA-Z0-9])\$([^$\n]+?)\$(?!\d)/', function ($m) use ($addPlaceholder) {
        $inner = $m[1];
        // 排除纯数字/纯价格（如 $5、$1.99）
        if (preg_match('/^\s*\d+(?:\.\d+)?\s*$/', $inner)) return '$' . $inner . '$';
        // 必须含 LaTeX 命令、运算符、上下标、希腊字母关键字等
        if (!preg_match('/[\\\\=+\-^_{}]|\\b(frac|sum|sqrt|int|alpha|beta|gamma|delta|pi|theta|infty|le|ge|ne|cdot|times|div|pm|mp|forall|exists|in|notin|subset|supset|cup|cap)\\b/', $inner)) {
            return '$' . $inner . '$';
        }
        return $addPlaceholder('<span class="math-inline">$' . $inner . '$</span>');
    }, $text);

    // 转义剩余 HTML（再还原占位符标记，避免后续替换失败）
    $text = htmlspecialchars($text, ENT_QUOTES, 'UTF-8');
    $text = preg_replace_callback('/&lt;!--MDPLACE(\d+)--&gt;/', function ($m) {
        return '<!--MDPLACE' . $m[1] . '-->';
    }, $text);

    // 5. 处理引用块嵌套（>> 表示二级引用）
    //    修复：旧逻辑只支持单层引用，多层 > 嵌套会被当成单层
    $lines = explode("\n", $text);
    $out = [];
    $n = count($lines);
    $i = 0;

    // 递归渲染块级内容（用于引用块/列表项内的多行内容）
    $renderBlockRecursive = function ($blockText) {
        if (trim($blockText) === '') return '';
        return renderMarkdown($blockText);
    };

    while ($i < $n) {
        $line = $lines[$i];
        $trimmed = trim($line);
        if ($trimmed === '') { $i++; continue; }

        // 占位符单独成块
        if (preg_match('/^<!--MDPLACE\d+-->$/', $trimmed)) {
            $out[] = $trimmed;
            $i++;
            continue;
        }

        // 标题（修复：严格要求 # 后有空格，避免 #hashtag 被误识别）
        if (preg_match('/^(#{1,6})\s+(.+)$/', $line, $mh)) {
            $level = strlen($mh[1]);
            $out[] = "<h{$level}>" . renderMarkdownInline(trim($mh[2])) . "</h{$level}>";
            $i++;
            continue;
        }

        // 分隔线（修复：要求整行只有 - _ * 且至少 3 个）
        if (preg_match('/^\s*([-*_])\1{2,}\s*$/', $line)) {
            $out[] = '<hr>';
            $i++;
            continue;
        }

        // 引用块（支持嵌套：递归调用 renderMarkdown 处理内部内容）
        // 修复：旧版把所有 > 行合并后只走 inline 渲染，导致引用内的列表/代码块/标题失效
        if (preg_match('/^\s*(?:>|&gt;)\s?/', $line)) {
            $quoteLines = [];
            while ($i < $n && preg_match('/^\s*(?:>|&gt;)\s?(.*)$/', $lines[$i], $qm)) {
                $quoteLines[] = $qm[1];
                $i++;
            }
            // 递归渲染引用块内容（支持嵌套引用、列表、代码块等）
            $innerHtml = $renderBlockRecursive(implode("\n", $quoteLines));
            $out[] = '<blockquote>' . $innerHtml . '</blockquote>';
            continue;
        }

        // 无序列表（支持嵌套：通过缩进判断子项）
        // 修复：旧版忽略缩进，所有同级；新版按缩进递归渲染子列表
        if (preg_match('/^\s*[-*+]\s+(.+)$/', $line)) {
            $listHtml = renderListBlock($lines, $i, 'ul', $renderBlockRecursive);
            $out[] = $listHtml['html'];
            $i = $listHtml['next'];
            continue;
        }

        // 有序列表
        if (preg_match('/^\s*\d+\.\s+(.+)$/', $line)) {
            $listHtml = renderListBlock($lines, $i, 'ol', $renderBlockRecursive);
            $out[] = $listHtml['html'];
            $i = $listHtml['next'];
            continue;
        }

        // 表格
        if (isTableBlock($lines, $i)) {
            $tableHtml = parseTableBlock($lines, $i);
            if ($tableHtml !== null) {
                $out[] = $tableHtml;
                continue;
            }
        }

        // 普通段落（修复：段落内若含占位符行，不应中断段落）
        $paraLines = [];
        while ($i < $n) {
            $pl = $lines[$i];
            if (trim($pl) === '') break;
            if (preg_match('/^#{1,6}\s+/', $pl)) break;
            if (preg_match('/^\s*([-*_])\1{2,}\s*$/', $pl)) break;
            if (preg_match('/^\s*(?:>|&gt;)\s?/', $pl)) break;
            if (preg_match('/^\s*[-*+]\s+/', $pl)) break;
            if (preg_match('/^\s*\d+\.\s+/', $pl)) break;
            if (preg_match('/^<!--MDPLACE\d+-->$/', trim($pl))) break;
            if (isTableBlock($lines, $i)) break;
            $paraLines[] = $pl;
            $i++;
        }
        // 行尾两个空格 = 硬换行：在该行末尾插入硬换行标记
        // 修复：每行末尾 2 空格 → 该行后强制换行；普通换行（无 2 空格）按 markdown 规范应合并为空格
        $renderedLines = [];
        foreach ($paraLines as $ln) {
            $hasHardBreak = preg_match('/  $/', $ln);
            $cleanLine = rtrim($ln);
            $renderedLines[] = ['text' => $cleanLine, 'hardBreak' => $hasHardBreak];
        }
        // 渲染每行 inline，按硬换行标记决定连接方式
        $parts = [];
        foreach ($renderedLines as $idx => $rl) {
            $parts[] = renderMarkdownInline($rl['text']);
            // 如果不是最后一行：硬换行用 <br>，软换行用空格
            if ($idx < count($renderedLines) - 1) {
                $parts[] = $rl['hardBreak'] ? '<br>' : ' ';
            } elseif ($rl['hardBreak']) {
                $parts[] = '<br>'; // 段落最后一行末尾的硬换行
            }
        }
        $out[] = '<p>' . implode('', $parts) . '</p>';
    }

    $html = implode("\n", $out);
    // 还原占位符
    foreach (array_reverse($placeholders) as $key => $value) {
        $html = str_replace($key, $value, $html);
    }
    return cacheSet($mdCacheKey, $html);
}

// 渲染列表块（支持嵌套子列表）
// 返回 ['html' => string, 'next' => int]
function renderListBlock(array $lines, int $start, string $listType, callable $renderBlockRecursive): array {
    $n = count($lines);
    $i = $start;
    // 获取起始行的缩进作为基准
    $baseIndent = 0;
    if (preg_match('/^(\s*)/', $lines[$i], $im)) {
        $baseIndent = strlen($im[1]);
    }
    $markerRegex = ($listType === 'ul') ? '/^(\s*)([-*+])\s+(.+)$/' : '/^(\s*)(\d+)\.\s+(.+)$/';

    $html = '<' . $listType . '>';
    while ($i < $n) {
        $line = $lines[$i];
        if (trim($line) === '') {
            // 空行：检查下一行是否仍是同级别列表项；否则结束
            if ($i + 1 < $n && preg_match($markerRegex, $lines[$i+1], $nextM) && strlen($nextM[1]) === $baseIndent) {
                $i++;
                continue;
            }
            break;
        }
        if (!preg_match($markerRegex, $line, $m)) break;
        $indent = strlen($m[1]);
        if ($indent < $baseIndent) break;
        if ($indent > $baseIndent) {
            // 子列表：递归渲染
            $sub = renderListBlock($lines, $i, $listType, $renderBlockRecursive);
            // 子列表附加到上一个 <li> 内
            if (!empty($html) && substr($html, -5) === '</li>') {
                $html = substr($html, 0, -5) . $sub['html'] . '</li>';
            } else {
                $html .= '<li>' . $sub['html'] . '</li>';
            }
            $i = $sub['next'];
            continue;
        }
        // 同级列表项
        $content = $m[3];
        // 收集列表项的续行（缩进大于基准的行，直到下一个同级标记或空行）
        $itemLines = [$content];
        $i++;
        while ($i < $n) {
            $nextLine = $lines[$i];
            if (trim($nextLine) === '') {
                // 空行后若仍是列表项则保留，否则结束续行
                if ($i + 1 < $n && preg_match($markerRegex, $lines[$i+1], $nextM2) && strlen($nextM2[1]) >= $baseIndent) {
                    $itemLines[] = '';
                    $i++;
                    continue;
                }
                break;
            }
            if (preg_match($markerRegex, $nextLine, $nm) && strlen($nm[1]) === $baseIndent) break;
            if (preg_match($markerRegex, $nextLine, $nm) && strlen($nm[1]) < $baseIndent) break;
            // 续行：加到当前项
            $itemLines[] = trim($nextLine);
            $i++;
        }
        $itemContent = implode("\n", $itemLines);
        // 若续行多于 1 行或含块级语法，递归渲染；否则仅 inline
        if (substr_count($itemContent, "\n") > 0 || preg_match('/^(\s*)([-*+]\s+|\d+\.\s+|>|&gt;|#{1,6}\s)/m', $itemContent)) {
            $itemHtml = $renderBlockRecursive($itemContent);
        } else {
            $itemHtml = renderMarkdownInline($itemContent);
        }
        $html .= '<li>' . $itemHtml . '</li>';
    }
    $html .= '</' . $listType . '>';
    return ['html' => $html, 'next' => $i];
}

// @username 渲染为带颜色的昵称链接 + Tag（仿洛谷 @ 渲染）
function renderMentionLink(string $rawName): string {
    $cacheKey = 'mention_' . $rawName;
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;

    $user = getUserByName($rawName);
    if (!$user) {
        return cacheSet($cacheKey, '@' . htmlspecialchars($rawName));
    }
    $fullUser = getUserById((int)$user['id']);
    if (!$fullUser) {
        return cacheSet($cacheKey, '@' . htmlspecialchars($rawName));
    }

    $uid = (int)$fullUser['id'];
    $profileUrl = '/user/' . $uid;

    if (!empty($fullUser['banned'])) {
        $html = '<a href="' . $profileUrl . '" class="mention-link mention-banned" style="color:var(--danger);font-weight:700;text-decoration:none;">@封禁用户</a>';
        return cacheSet($cacheKey, $html);
    }

    $color = getUserDisplayColor($fullUser);
    $displayName = !empty($fullUser['nickname']) ? $fullUser['nickname'] : ($fullUser['username'] ?? $rawName);
    $tag = !empty($fullUser['luogu_hook']) ? $fullUser['luogu_hook'] : ($fullUser['tag'] ?? '');

    $html = '<a href="' . $profileUrl . '" class="mention-link" style="color:' . $color . ';font-weight:700;text-decoration:none;">@' . htmlspecialchars($displayName) . '</a>';
    if ($tag !== '') {
        $html .= ' <span class="custom-tag" style="color:' . $color . ';">' . htmlspecialchars($tag) . '</span>';
    }
    return cacheSet($cacheKey, $html);
}

function renderMarkdownInline($text) {
    // 修复：图片必须在链接之前处理（否则 ![alt](url) 会被链接规则吞掉）
    // 图片 ![alt](url)
    $text = preg_replace_callback('/!\[([^\]]*)\]\(([^\s)]+)(?:\s+"[^"]*")?\)/', function ($m) {
        $alt = htmlspecialchars($m[1], ENT_QUOTES, 'UTF-8');
        $url = htmlspecialchars(assetUrl($m[2]), ENT_QUOTES, 'UTF-8');
        return '<img src="' . $url . '" alt="' . $alt . '" style="max-width:100%;border-radius:8px;" loading="lazy">';
    }, $text);
    // 链接 [text](url) — 支持 title
    $text = preg_replace_callback('/\[([^\]]+)\]\(([^\s)]+)(?:\s+"[^"]*")?\)/', function ($m) {
        $title = renderMarkdownInline($m[1]);
        $url = htmlspecialchars(assetUrl($m[2]), ENT_QUOTES, 'UTF-8');
        return '<a href="' . $url . '" target="_blank" rel="noopener noreferrer">' . $title . '</a>';
    }, $text);

    // 自动链接裸 URL（修复：排除已被 <a href="..."> 包裹的 URL，避免双重嵌套）
    $text = preg_replace_callback('/(?<!["\'>=])((?:https?:\/\/|www\.)[^\s<>\)\]]+)/', function ($m) {
        $url = $m[1];
        $href = (strpos($url, 'http://') !== 0 && strpos($url, 'https://') !== 0) ? 'https://' . $url : $url;
        $urlEsc = htmlspecialchars($url, ENT_QUOTES, 'UTF-8');
        $hrefEsc = htmlspecialchars($href, ENT_QUOTES, 'UTF-8');
        return '<a href="' . $hrefEsc . '" target="_blank" rel="noopener noreferrer">' . $urlEsc . '</a>';
    }, $text);

    // @提及：先抽取为占位符，避免被后续加粗/斜体干扰
    // 仅在 @ 前非字母/数字/下划线/中文/@ 时匹配（排除邮箱 user@host）
    $mentionMap = [];
    $text = preg_replace_callback('/(?<![a-zA-Z0-9_\x{4e00}-\x{9fa5}@])@([a-zA-Z0-9_\x{4e00}-\x{9fa5}]{1,50})/u', function ($m) use (&$mentionMap) {
        $key = "\x00MENTION" . count($mentionMap) . "\x00";
        $mentionMap[$key] = $m[1];
        return $key;
    }, $text);

    // 修复：删除线优先于粗体/斜体（避免 ~~**text**~~ 解析错乱）
    $text = preg_replace('/~~(?!\s)(.+?)(?<!\s)~~/s', '<del>$1</del>', $text);
    // 修复：粗体必须先于斜体（否则 **text** 会被斜体规则部分吞掉）
    $text = preg_replace('/\*\*(?!\s)(.+?)(?<!\s)\*\*/s', '<strong>$1</strong>', $text);
    $text = preg_replace('/__(?!\s)(.+?)(?<!\s)__/s', '<strong>$1</strong>', $text);
    // 斜体：单 * 或单 _
    // 修复：_ 不能紧跟字母/数字（避免 target="_blank" 中的 _b 被吞），且不能在标识符中间
    // 修复：使用 word boundary 排除 _ 在 identifier 中间的情况
    $text = preg_replace('/(?<!\*)\*(?!\s)([^*]+?)(?<!\s)\*(?!\*)/s', '<em>$1</em>', $text);
    // _ 斜体：只在 _ 前后都不是单词字符时才生效（避免 snake_case_var 被破坏）
    $text = preg_replace('/(?<![a-zA-Z0-9_])_(?!\s)([^_]+?)(?<!\s)_(?![a-zA-Z0-9_])/s', '<em>$1</em>', $text);

    // 还原 @提及 为彩色链接
    if (!empty($mentionMap)) {
        foreach ($mentionMap as $key => $username) {
            $text = str_replace($key, renderMentionLink($username), $text);
        }
    }

    return $text;
}

function isTableBlock(array $lines, int $i): bool {
    if (!isset($lines[$i], $lines[$i + 1])) return false;
    $first = trim($lines[$i]);
    $second = trim($lines[$i + 1]);
    if ($first === '' || $first[0] !== '|') return false;
    if (!preg_match('/^\|?(?:\s*:?-+:?\s*\|)+\s*:?-+:?\s*\|?$/', $second)) return false;
    return true;
}

function parseTableBlock(array &$lines, int &$i): ?string {
    $headerLine = trim($lines[$i]);
    $sepLine = trim($lines[$i + 1]);
    $i += 2;
    $headers = array_map('trim', explode('|', trim($headerLine, '|')));
    $aligns = [];
    foreach (array_map('trim', explode('|', trim($sepLine, '|'))) as $col) {
        if (preg_match('/^:-+:$/', $col)) $aligns[] = 'center';
        elseif (preg_match('/^-+:$/', $col)) $aligns[] = 'right';
        else $aligns[] = 'left';
    }
    $html = '<table class="md-table"><thead><tr>';
    foreach ($headers as $idx => $h) {
        $align = $aligns[$idx] ?? 'left';
        $html .= '<th style="text-align:' . $align . '">' . renderMarkdownInline($h) . '</th>';
    }
    $html .= '</tr></thead><tbody>';
    while ($i < count($lines)) {
        $line = trim($lines[$i]);
        if ($line === '') break;
        if ($line[0] !== '|') break;
        $cells = array_map('trim', explode('|', trim($line, '|')));
        $html .= '<tr>';
        foreach ($headers as $idx => $_) {
            $cell = $cells[$idx] ?? '';
            $align = $aligns[$idx] ?? 'left';
            $html .= '<td style="text-align:' . $align . '">' . renderMarkdownInline($cell) . '</td>';
        }
        $html .= '</tr>';
        $i++;
    }
    $html .= '</tbody></table>';
    return $html;
}
// 操作日志：记录全站写操作的操作人、IP、目标、状态等
// $action 操作类型（如 login/create_post/send_message）
// $targetType 目标对象类型（如 user/post/message/problem）
// $targetId 目标对象 ID（字符串以兼容非数字 ID）
// $detail 详情（数组或字符串），$status success/failed
function logOperation(string $action, string $targetType = '', $targetId = '', $detail = null, string $status = 'success'): void
{
    try {
        $db = getDB();
        $user = getCurrentUser();
        $userId = $user['id'] ?? null;
        $username = $user['username'] ?? '';
        $ip = getUserIP();
        $ua = substr($_SERVER['HTTP_USER_AGENT'] ?? '', 0, 500);
        $detailJson = is_array($detail) ? json_encode($detail, JSON_UNESCAPED_UNICODE) : (string)$detail;
        if (mb_strlen($detailJson, 'UTF-8') > 65000) {
            $detailJson = mb_substr($detailJson, 0, 65000, 'UTF-8');
        }
        $db->prepare('INSERT INTO operation_log (user_id, username, ip, action, target_type, target_id, detail, status, user_agent, created_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, NOW())')
            ->execute([$userId, $username, $ip, $action, $targetType, (string)$targetId, $detailJson, $status, $ua]);
    } catch (Throwable $e) {
        error_log('[logOperation] failed: ' . $e->getMessage());
    }
}
// 清理超过指定天数的操作日志（由 cron 调用）
function purgeOldOperationLogs(int $days = 90): int
{
    try {
        $db = getDB();
        $stmt = $db->prepare("DELETE FROM operation_log WHERE created_at < DATE_SUB(NOW(), INTERVAL ? DAY)");
        $stmt->bindValue(1, $days, PDO::PARAM_INT);
        $stmt->execute();
        return $stmt->rowCount();
    } catch (Throwable $e) {
        error_log('[purgeOldOperationLogs] failed: ' . $e->getMessage());
        return 0;
    }
}
// 通知系统
function addNotification($user_id, $type, $content, $link = null, $source = null) {
    $db = getDB();
    try {
        $stmt = $db->prepare("INSERT INTO notifications (user_id, type, content, link, source) VALUES (?, ?, ?, ?, ?)");
        $stmt->execute([$user_id, $type, $content, $link, $source]);
        cacheClear('unread_notif_' . (int)$user_id);
    } catch (PDOException $e) {
        error_log('[addNotification] failed: ' . $e->getMessage());
    }
}
// 通知 @提及：一次性查全部用户 + 一条多值 INSERT，避免 N+1
function notifyMentions($content, $sourceType, $sourceId, $senderId, $link = '') {
    preg_match_all('/(?<![a-zA-Z0-9_\x{4e00}-\x{9fa5}@])@([a-zA-Z0-9_\x{4e00}-\x{9fa5}]{1,50})/u', $content, $matches);
    if (empty($matches[1])) return;

    $names = array_values(array_unique($matches[1]));
    if (empty($names)) return;

    $db = getDB();
    try {
        $placeholders = implode(',', array_fill(0, count($names), '?'));
        $stmt = $db->prepare("SELECT DISTINCT id FROM users WHERE (username IN ($placeholders) OR nickname IN ($placeholders)) AND id != ?");
        $params = array_merge($names, $names, [$senderId]);
        $stmt->execute($params);
        $users = $stmt->fetchAll(PDO::FETCH_ASSOC);
        if (empty($users)) return;

        $notifiedIds = [];
        foreach ($users as $u) {
            $notifiedIds[(int)$u['id']] = true;
        }
        if (empty($notifiedIds)) return;

        $rows = [];
        $params = [];
        foreach ($notifiedIds as $uid => $_) {
            $rows[] = '(?, ?, ?, ?, ?)';
            $params[] = $uid;
            $params[] = 'mention';
            $params[] = '您被 @ 提及';
            $params[] = $link;
            $params[] = $sourceType;
        }
        $sql = 'INSERT INTO notifications (user_id, type, content, link, source) VALUES ' . implode(', ', $rows);
        $db->prepare($sql)->execute($params);

        foreach ($notifiedIds as $uid => $_) {
            cacheClear('unread_notif_' . $uid);
        }
    } catch (PDOException $e) {
        error_log('[notifyMentions] failed: ' . $e->getMessage());
    }
}
function getUnreadCount($user_id) {
    $user_id = (int)$user_id;
    $ck = 'unread_notif_' . $user_id;
    $v = cacheGet($ck);
    if ($v !== null) return (int)$v;
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT COUNT(*) FROM notifications WHERE user_id = ? AND is_read = 0");
        $stmt->execute([$user_id]);
        $cnt = (int)$stmt->fetchColumn();
        cacheSet($ck, $cnt, 15);
        return $cnt;
    } catch (PDOException $e) {
        error_log('[getUnreadCount] failed: ' . $e->getMessage());
        return 0;
    }
}
function getUnreadMessageCount($user_id) {
    $user_id = (int)$user_id;
    $ck = 'unread_msg_' . $user_id;
    $v = cacheGet($ck);
    if ($v !== null) return (int)$v;
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT COUNT(*) FROM private_messages WHERE receiver_id = ? AND is_read = 0");
        $stmt->execute([$user_id]);
        $cnt = (int)$stmt->fetchColumn();
        cacheSet($ck, $cnt, 15);
        return $cnt;
    } catch (PDOException $e) {
        error_log('[getUnreadMessageCount] failed: ' . $e->getMessage());
        return 0;
    }
}
function getNotifications($user_id, $limit = 20) {
    $db = getDB();
    try {
        $updateStmt = $db->prepare("UPDATE notifications SET is_read = 1 WHERE user_id = ? AND is_read = 0");
        $updateStmt->bindValue(1, $user_id, PDO::PARAM_INT);
        $updateStmt->execute();
        $stmt = $db->prepare("SELECT * FROM notifications WHERE user_id = ? ORDER BY created_at DESC LIMIT ?");
        $stmt->bindValue(1, $user_id, PDO::PARAM_INT);
        $stmt->bindValue(2, $limit, PDO::PARAM_INT);
        $stmt->execute();
        return $stmt->fetchAll(PDO::FETCH_ASSOC);
    } catch (PDOException $e) {
        error_log('[getNotifications] failed: ' . $e->getMessage());
        return [];
    }
}
function markNotificationRead($notif_id, $user_id) {
    $db = getDB();
    try {
        $stmt = $db->prepare("UPDATE notifications SET is_read = 1 WHERE id = ? AND user_id = ?");
        $stmt->execute([$notif_id, $user_id]);
    } catch (PDOException $e) {
        error_log('[markNotificationRead] failed: ' . $e->getMessage());
    }
}
// 删除指定通知：失败时返回 false 让前端感知
function deleteNotifications($user_id, array $ids) {
    if (empty($ids)) return false;
    $db = getDB();
    $ph = implode(',', array_fill(0, count($ids), '?'));
    $params = array_merge([$user_id], $ids);
    try {
        $db->prepare("DELETE FROM notifications WHERE user_id = ? AND id IN ($ph)")->execute($params);
        return true;
    } catch (PDOException $e) {
        error_log('[deleteNotifications] failed: ' . $e->getMessage());
        return false;
    }
}
function clearAllNotifications($user_id) {
    $db = getDB();
    try {
        $db->prepare("DELETE FROM notifications WHERE user_id = ?")->execute([$user_id]);
    } catch (PDOException $e) {
        error_log('[clearAllNotifications] failed: ' . $e->getMessage());
    }
}
// IP 相关
// 仅在可信代理（本机/内网/回环）时才采用 X-Forwarded-For / CF-Connecting-IP / X-Real-IP，
// 否则用 REMOTE_ADDR，避免攻击者伪造头绕过封禁/限流。
function getUserIP() {
    $remote = $_SERVER['REMOTE_ADDR'] ?? '';
    $isTrustedProxy = false;
    if ($remote && filter_var($remote, FILTER_VALIDATE_IP)) {
        $isPrivate = !filter_var($remote, FILTER_VALIDATE_IP, FILTER_FLAG_NO_PRIV_RANGE | FILTER_FLAG_NO_RES_RANGE);
        if ($isPrivate || $remote === '127.0.0.1' || $remote === '::1') {
            $isTrustedProxy = true;
        }
    } elseif ($remote === '' && (PHP_SAPI === 'cli' || PHP_SAPI === 'cli-server')) {
        $isTrustedProxy = true;
    }
    if ($isTrustedProxy) {
        $candidates = [
            $_SERVER['HTTP_CF_CONNECTING_IP'] ?? null,
            $_SERVER['HTTP_X_FORWARDED_FOR'] ?? null,
            $_SERVER['HTTP_X_REAL_IP'] ?? null,
        ];
        foreach ($candidates as $ip) {
            if (empty($ip)) continue;
            // X-Forwarded-For 可能为 "client, proxy1, proxy2"，取最左侧
            if (strpos($ip, ',') !== false) {
                $ip = trim(explode(',', $ip)[0]);
            }
            $ip = trim($ip);
            if (filter_var($ip, FILTER_VALIDATE_IP)) {
                return $ip;
            }
        }
    }
    if ($remote && filter_var($remote, FILTER_VALIDATE_IP)) {
        return $remote;
    }
    return '0.0.0.0';
}
function isIpBanned($ip) {
    $cacheKey = 'ip_banned_' . $ip;
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;

    $db = getDB();
    // 顺带清理本次 IP 的过期封禁记录
    try {
        $db->prepare("DELETE FROM banned_ips WHERE ip = ? AND expires_at IS NOT NULL AND expires_at <= NOW()")->execute([$ip]);
    } catch (PDOException $e) {
        error_log('[isIpBanned] cleanup failed: ' . $e->getMessage());
    }
    try {
        $stmt = $db->prepare("SELECT 1 FROM banned_ips WHERE ip = ? AND (expires_at IS NULL OR expires_at > NOW())");
        $stmt->execute([$ip]);
        return cacheSet($cacheKey, $stmt->fetchColumn() > 0);
    } catch (PDOException $e) {
        error_log('[isIpBanned] failed: ' . $e->getMessage());
        return false;
    }
}
function addBannedIp($ip, $reason, $admin_id, $duration = null) {
    cacheClear('ip_banned_' . $ip);
    $db = getDB();
    $expiresAt = null;
    if ($duration !== null && $duration > 0) {
        $expiresAt = date('Y-m-d H:i:s', time() + $duration);
    }
    $stmt = $db->prepare("INSERT INTO banned_ips (ip, reason, created_by, expires_at) VALUES (?, ?, ?, ?)
                          ON DUPLICATE KEY UPDATE reason = VALUES(reason), created_by = VALUES(created_by), expires_at = VALUES(expires_at), created_at = CURRENT_TIMESTAMP");
    return $stmt->execute([$ip, $reason, $admin_id, $expiresAt]);
}
function removeBannedIp($ip) {
    cacheClear('ip_banned_' . $ip);
    $db = getDB();
    $stmt = $db->prepare("DELETE FROM banned_ips WHERE ip = ?");
    return $stmt->execute([$ip]);
}
function getBannedIps() {
    $db = getDB();
    return $db->query("SELECT b.*, u.username as admin_name,
                              CASE
                                  WHEN b.expires_at IS NULL THEN 0
                                  WHEN b.expires_at > NOW() THEN 1
                                  ELSE 2
                              END as ban_status
                       FROM banned_ips b
                       LEFT JOIN users u ON b.created_by = u.id
                       ORDER BY ban_status ASC, b.created_at DESC LIMIT 500")->fetchAll(PDO::FETCH_ASSOC);
}
function isForumPostLocked($postId) {
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT locked FROM forum_posts WHERE id = ?");
        $stmt->execute([(int)$postId]);
        return (bool)$stmt->fetchColumn();
    } catch (PDOException $e) {
        error_log('[isForumPostLocked] failed: ' . $e->getMessage());
        return false;
    }
}

// canDeleteContent / canManageContent 已迁移至 admin_roles.php

// HTTP GET 请求（cURL 优先，file_get_contents 回退）
function httpGet($url, $headers = []) {
    $defaultHeaders = [
        'User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
        'Accept: text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
        'Accept-Language: zh-CN,zh;q=0.9',
    ];
    $headers = array_merge($defaultHeaders, $headers);

    if (function_exists('curl_init')) {
        $ch = curl_init();
        if ($ch !== false) {
            curl_setopt_array($ch, [
                CURLOPT_URL => $url,
                CURLOPT_RETURNTRANSFER => true,
                CURLOPT_SSL_VERIFYPEER => true,
                CURLOPT_TIMEOUT => 15,
                CURLOPT_CONNECTTIMEOUT => 5,
                CURLOPT_FOLLOWLOCATION => true,
                CURLOPT_MAXREDIRS => 5,
                CURLOPT_ENCODING => '',
                CURLOPT_HTTPHEADER => $headers,
            ]);
            $body = curl_exec($ch);
            $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
            curl_close($ch);
            if ($body !== false && $httpCode < 400) {
                return $body;
            }
        }
    }

    $opts = [
        'http' => [
            'method' => 'GET',
            'header' => implode("\r\n", $headers) . "\r\n",
            'timeout' => 15,
            'follow_location' => 1,
            'max_redirects' => 5,
        ],
        'ssl' => [
            'verify_peer' => true,
            'verify_peer_name' => true,
        ],
    ];
    $context = stream_context_create($opts);
    $body = @file_get_contents($url, false, $context);
    return $body !== false ? $body : false;
}

// 获取洛谷用户页面 HTML（优先 _contentOnly=1 JSON，失败回退 HTML 页面）
function getLuoguPage($uid) {
    $json = httpGet("https://www.luogu.com.cn/user/{$uid}?_contentOnly=1", [
        'Referer: https://www.luogu.com.cn/',
        'x-lentille-request: content-only',
        'x-luogu-type: content-only',
    ]);
    if ($json !== false) {
        $data = json_decode($json, true);
        if ($data && (isset($data['code']) || isset($data['currentData']) || isset($data['data']))) {
            return $json;
        }
    }
    return httpGet("https://www.luogu.com.cn/user/{$uid}", [
        'Referer: https://www.luogu.com.cn/',
    ]);
}

// 通过洛谷 API 获取用户信息
function getLuoguUserInfo($uid) {
    $json = httpGet("https://www.luogu.com.cn/user/{$uid}?_contentOnly=1", [
        'Referer: https://www.luogu.com.cn/',
        'x-lentille-request: content-only',
        'x-luogu-type: content-only',
    ]);
    if ($json === false) {
        return ['success' => false, 'error' => '无法连接洛谷API'];
    }

    $data = json_decode($json, true);
    if (!$data) {
        return ['success' => false, 'error' => '洛谷API返回数据格式错误'];
    }

    $user = null;
    if (isset($data['currentData']['user']) && is_array($data['currentData']['user'])) {
        $user = $data['currentData']['user'];
    } elseif (isset($data['data']['user']) && is_array($data['data']['user'])) {
        $user = $data['data']['user'];
    } elseif (isset($data['user']) && is_array($data['user'])) {
        $user = $data['user'];
    }

    if ($user === null) {
        return ['success' => false, 'error' => '无法从洛谷API提取用户数据'];
    }

    return ['success' => true, 'data' => $user];
}

// 从洛谷页面内容提取用户 JSON（兼容 HTML 和 API 响应）
function parseLuoguJson($html) {
    if (empty($html)) return null;

    $data = json_decode($html, true);
    if ($data) {
        foreach ([
            ['currentData', 'user'],
            ['data', 'user'],
            ['user'],
            ['data', 'data', 'user'],
            ['currentData', 'data', 'user'],
        ] as $path) {
            $ref = $data;
            $ok = true;
            foreach ($path as $key) {
                if (!isset($ref[$key]) || !is_array($ref[$key])) { $ok = false; break; }
                $ref = $ref[$key];
            }
            if ($ok && isset($ref['name'])) {
                return $ref;
            }
        }
    }

    if (preg_match('/<script\s+id="lentille-context"[^>]*>(.*?)<\/script>/s', $html, $m)) {
        $data = json_decode($m[1], true);
        if ($data) {
            foreach ([
                ['data', 'user'],
                ['currentData', 'user'],
                ['data', 'data', 'user'],
                ['currentData', 'data', 'user'],
                ['user'],
            ] as $path) {
                $ref = $data;
                $ok = true;
                foreach ($path as $key) {
                    if (!isset($ref[$key]) || !is_array($ref[$key])) { $ok = false; break; }
                    $ref = $ref[$key];
                }
                if ($ok && isset($ref['name'])) {
                    return $ref;
                }
            }
        }
    }

    return null;
}

// 洛谷名字颜色枚举到十六进制
function luoguColorMap(): array {
    return [
        'Gray'    => '#bfbfbf',
        'Green'   => '#52c41a',
        'Blue'    => '#3498db',
        'Purple'  => '#9d3dcf',
        'Orange'  => '#f39c11',
        'Red'     => '#fe4c61',
        'Black'   => '#000000',
        'Brown'   => '#ad8b00',
        'Cheater' => '#000000',
    ];
}

function parseLuoguColor($html) {
    $user = parseLuoguJson($html);
    if ($user && !empty($user['color'])) {
        return luoguColorMap()[$user['color']] ?? '#fe4c61';
    }
    return '#fe4c61';
}

function parseLuoguHook($html) {
    $user = parseLuoguJson($html);
    if ($user && isset($user['badge']) && $user['badge'] !== '') {
        return $user['badge'];
    }
    if (preg_match('/<span[^>]*class="[^"]*\bbadge\b[^"]*"[^>]*>(.*?)<\/span>/s', $html, $m)) {
        $text = trim(strip_tags($m[1]));
        if ($text !== '') return $text;
    }
    return '';
}

// 验证洛谷用户签名中是否包含验证码
function verifyLuoguCode($luogu_uid, $verify_code) {
    if (empty($luogu_uid) || empty($verify_code)) {
        return ['success' => false, 'message' => 'UID和验证码不能为空'];
    }

    $apiResult = getLuoguUserInfo($luogu_uid);
    if ($apiResult['success']) {
        $intro = $apiResult['data']['introduction'] ?? '';
        if (strpos($intro, $verify_code) !== false) {
            return ['success' => true, 'message' => '验证成功'];
        }
    }

    $html = getLuoguPage($luogu_uid);
    if ($html === false || empty($html)) {
        return ['success' => false, 'message' => '无法访问洛谷用户页面，请稍后重试或检查UID是否正确'];
    }

    if (preg_match('/<script\s+id="lentille-context"\s+type="application\/json"\s*>(.*?)<\/script>/s', $html, $m)) {
        $data = json_decode($m[1], true);
        if ($data) {
            $user = null;
            if (isset($data['data']['user']) && is_array($data['data']['user'])) {
                $user = $data['data']['user'];
            } elseif (isset($data['currentData']['user']) && is_array($data['currentData']['user'])) {
                $user = $data['currentData']['user'];
            }
            if ($user) {
                $intro = $user['introduction'] ?? '';
                if (strpos($intro, $verify_code) !== false) {
                    return ['success' => true, 'message' => '验证成功'];
                }
            }
        }
    }

    $plain = html_entity_decode(strip_tags($html));
    if (strpos($plain, $verify_code) !== false) {
        return ['success' => true, 'message' => '验证成功'];
    }

    return ['success' => false, 'message' => '验证失败，请确保您在洛谷个人签名中填入了验证码 "' . $verify_code . '"'];
}

// 同步用户洛谷状态（管理员只能刷新钩子）
function syncLuoguStatus($user_id, $admin_action = false) {
    $user = getUserById($user_id);
    if (!$user) {
        return ['success' => false, 'message' => '用户不存在'];
    }
    if (empty($user['luogu_uid']) || empty($user['luogu_verified'])) {
        return ['success' => false, 'message' => '未绑定洛谷账号'];
    }

    $luoguResult = getLuoguUserInfo($user['luogu_uid']);
    if (!$luoguResult['success']) {
        $html = getLuoguPage($user['luogu_uid']);
        if ($html === false) {
            return ['success' => false, 'message' => '无法获取洛谷页面，请稍后重试'];
        }
        $hook = parseLuoguHook($html);
        $color = parseLuoguColor($html);
    } else {
        $luoguUser = $luoguResult['data'];
        $hook = $luoguUser['badge'] ?? '';
        $color = luoguColorMap()[$luoguUser['color'] ?? ''] ?? '#fe4c61';
    }

    $db = getDB();
    $stmt = $db->prepare("UPDATE users SET luogu_hook = ?, luogu_color = ?, luogu_synced_at = NOW() WHERE id = ?");
    $stmt->execute([$hook, $color, $user_id]);
    clearUserCache($user_id);
    return ['success' => true, 'message' => '同步成功', 'hook' => $hook, 'color' => $color];
}
// 刷新所有已绑定洛谷账号的用户状态（定时任务）
function syncAllLuoguStatus() {
    $db = getDB();
    try {
        $stmt = $db->query("SELECT id FROM users WHERE luogu_verified = 1 AND luogu_uid != ''");
        $users = $stmt->fetchAll(PDO::FETCH_ASSOC);
    } catch (PDOException $e) {
        error_log('[syncAllLuoguStatus] failed: ' . $e->getMessage());
        return ['success' => false, 'message' => '查询失败'];
    }
    $success = 0;
    $failed = 0;
    foreach ($users as $u) {
        $res = syncLuoguStatus($u['id'], false);
        if ($res['success']) $success++; else $failed++;
        usleep(200000);
    }
    return ['success' => true, 'message' => "同步完成：成功 {$success} 人，失败 {$failed} 人"];
}
// 更新用户最后活动时间（节流：60 秒内只更新一次）
function updateUserActivity($user_id) {
    $user_id = (int)$user_id;
    if ($user_id <= 0) return;
    $cacheKey = 'user_activity_' . $user_id;
    if (cacheGet($cacheKey) !== null) return;
    try {
        $db = getDB();
        $stmt = $db->prepare("UPDATE users SET last_activity = NOW() WHERE id = ?");
        $stmt->execute([$user_id]);
        cacheSet($cacheKey, time(), 60);
    } catch (PDOException $e) {
        error_log('[updateUserActivity] failed: ' . $e->getMessage());
    }
}
// 用户是否在线（5 分钟内有过活动）
function isUserOnline($user_id) {
    $user = getUserById((int)$user_id);
    if (!$user || empty($user['last_activity'])) return false;
    return strtotime($user['last_activity']) > time() - 300;
}
// 某洛谷UID已绑定本站账号数量
function getLuoguBindCount($uid) {
    $db = getDB();
    $stmt = $db->prepare("SELECT COUNT(*) FROM users WHERE luogu_uid = ? AND luogu_verified = 1");
    $stmt->execute([$uid]);
    return (int)$stmt->fetchColumn();
}
// 用户公开信息（个人主页）
function getUserPublicInfo($user_id) {
    $db = getDB();
    $stmt = $db->prepare("SELECT id, username, nickname, bio, role, tag, luogu_uid, luogu_verified, luogu_color, luogu_hook, avatar, created_at, banned FROM users WHERE id = ?");
    $stmt->execute([$user_id]);
    return $stmt->fetch(PDO::FETCH_ASSOC);
}

// 通过用户名或昵称查找用户
function getUserByName($name) {
    $db = getDB();
    $stmt = $db->prepare("SELECT id, username, nickname FROM users WHERE username = ? OR nickname = ? LIMIT 1");
    $stmt->execute([$name, $name]);
    return $stmt->fetch(PDO::FETCH_ASSOC);
}

// 校验用户名格式：字母/数字/下划线，3-20 位，不能以数字开头
function isValidUsername(string $username): bool {
    return (bool)preg_match('/^[A-Za-z_][A-Za-z0-9_]{2,19}$/', $username);
}

// 站点布局内渲染内联错误页（返回 HTML 字符串，调用方负责 echo 和 http_response_code）
function renderInlineError(int $code, string $title = '', string $subtitle = ''): string {
    $map = [
        400 => ['title' => '请求错误', 'subtitle' => '服务器无法理解这个请求。', 'color' => '#f59e0b', 'emoji' => '⚠️'],
        401 => ['title' => '未登录', 'subtitle' => '此页面需要登录后才能访问。', 'color' => '#f59e0b', 'emoji' => '🔒'],
        403 => ['title' => '禁止访问', 'subtitle' => '您没有权限查看此页面或执行此操作。', 'color' => '#ef4444', 'emoji' => '⛔'],
        404 => ['title' => '页面不存在', 'subtitle' => '您访问的页面可能已被删除、改名或从未存在。', 'color' => '#3b82f6', 'emoji' => '🔍'],
        500 => ['title' => '服务器内部错误', 'subtitle' => '服务器遇到了一些问题，我们正在修复中。', 'color' => '#ef4444', 'emoji' => '💥'],
        503 => ['title' => '服务不可用', 'subtitle' => '服务器正在维护或暂时过载，请稍后再试。', 'color' => '#f59e0b', 'emoji' => '🛠️'],
        505 => ['title' => 'HTTP 版本不支持', 'subtitle' => '服务器不支持请求中使用的 HTTP 协议版本。', 'color' => '#ef4444', 'emoji' => '📡'],
    ];
    $info = $map[$code] ?? ['title' => '出错了', 'subtitle' => '发生了一些问题，请稍后重试。', 'color' => '#ef4444', 'emoji' => '❌'];
    if ($title !== '') $info['title'] = $title;
    if ($subtitle !== '') $info['subtitle'] = $subtitle;
    $title = htmlspecialchars($info['title']);
    $subtitle = htmlspecialchars($info['subtitle']);
    $color = htmlspecialchars($info['color']);
    $emoji = $info['emoji'];
    return <<<HTML
<div class="inline-error-card" style="max-width:520px;margin:24px auto;text-align:center;background:var(--card-bg);border:1px solid var(--card-border);border-radius:16px;padding:48px 32px;box-shadow:var(--shadow);position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;right:0;height:6px;background:{$color};"></div>
    <div style="font-size:64px;line-height:1;margin-bottom:12px;">{$emoji}</div>
    <div style="font-size:72px;font-weight:900;line-height:1;color:{$color};margin-bottom:6px;letter-spacing:-2px;">{$code}</div>
    <h1 style="font-size:20px;font-weight:700;color:var(--text-main);margin-bottom:10px;">{$title}</h1>
    <p style="font-size:14px;color:var(--text-muted);margin-bottom:24px;line-height:1.7;">{$subtitle}</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="btn btn-primary">返回首页</a>
        <button type="button" class="btn" onclick="history.back()" style="background:var(--input-bg);border:1px solid var(--input-border);">返回上一页</button>
    </div>
</div>
HTML;
}

// 用户名/昵称关键词联想搜索（纯数字时同时按 ID 匹配）
// ATTR_EMULATE_PREPARES=false 模式下 LIMIT ? 必须用 bindValue(PARAM_INT)
function searchUsersByName($keyword, $limit = 10) {
    $db = getDB();
    $like = '%' . $keyword . '%';
    if (ctype_digit($keyword)) {
        $stmt = $db->prepare("SELECT id, username, nickname, role FROM users WHERE username LIKE ? OR nickname LIKE ? OR id = ? ORDER BY id ASC LIMIT ?");
        $stmt->bindValue(1, $like, PDO::PARAM_STR);
        $stmt->bindValue(2, $like, PDO::PARAM_STR);
        $stmt->bindValue(3, (int)$keyword, PDO::PARAM_INT);
        $stmt->bindValue(4, (int)$limit, PDO::PARAM_INT);
    } else {
        $stmt = $db->prepare("SELECT id, username, nickname, role FROM users WHERE username LIKE ? OR nickname LIKE ? ORDER BY id ASC LIMIT ?");
        $stmt->bindValue(1, $like, PDO::PARAM_STR);
        $stmt->bindValue(2, $like, PDO::PARAM_STR);
        $stmt->bindValue(3, (int)$limit, PDO::PARAM_INT);
    }
    $stmt->execute();
    return $stmt->fetchAll(PDO::FETCH_ASSOC);
}

function getArticleReplies($articleId) {
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT r.*, u.id AS user_id, u.username, u.nickname, u.role, u.tag, u.banned, u.luogu_color, u.luogu_hook, u.avatar FROM article_replies r LEFT JOIN users u ON r.user_id = u.id WHERE r.article_id = ? ORDER BY r.created_at ASC LIMIT 200");
        $stmt->execute([(int)$articleId]);
        return $stmt->fetchAll(PDO::FETCH_ASSOC);
    } catch (PDOException $e) {
        error_log('[getArticleReplies] failed: ' . $e->getMessage());
        return [];
    }
}

function canDeleteArticleReply($reply, $currentUser) {
    if (!$currentUser) return false;
    if (isAdmin($currentUser['id'])) return true;
    return (int)$reply['user_id'] === (int)$currentUser['id'];
}

function getSiteRules() {
    $db = getDB();
    try {
        $stmt = $db->query("SELECT * FROM site_rules ORDER BY updated_at DESC LIMIT 1");
        $row = $stmt->fetch(PDO::FETCH_ASSOC);
        if ($row) {
            $updater = getUserById($row['updated_by']);
            $row['updater_name'] = !empty($updater['nickname']) ? $updater['nickname'] : ($updater['username'] ?? '未知');
        }
        return $row;
    } catch (PDOException $e) {
        error_log('[getSiteRules] failed: ' . $e->getMessage());
        return null;
    }
}
// 站点自定义页面（管理员后台编辑，前台展示）
function getSitePage(string $slug): ?array {
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT * FROM site_pages WHERE slug = ? LIMIT 1");
        $stmt->execute([$slug]);
        $row = $stmt->fetch(PDO::FETCH_ASSOC);
        if ($row) {
            $updater = getUserById($row['updated_by']);
            $row['updater_name'] = !empty($updater['nickname']) ? $updater['nickname'] : ($updater['username'] ?? '未知');
        }
        return $row ?: null;
    } catch (PDOException $e) {
        error_log('[getSitePage] failed: ' . $e->getMessage());
        return null;
    }
}
function updateSitePage(string $slug, string $title, string $content, int $updatedBy): bool {
    $db = getDB();
    try {
        $existing = $db->prepare("SELECT id FROM site_pages WHERE slug = ? LIMIT 1");
        $existing->execute([$slug]);
        $id = $existing->fetchColumn();
        if ($id) {
            $db->prepare("UPDATE site_pages SET title = ?, content = ?, updated_by = ? WHERE id = ?")
                ->execute([$title, $content, $updatedBy, $id]);
        } else {
            $db->prepare("INSERT INTO site_pages (slug, title, content, updated_by) VALUES (?, ?, ?, ?)")
                ->execute([$slug, $title, $content, $updatedBy]);
        }
        return true;
    } catch (PDOException $e) {
        error_log('[updateSitePage] failed: ' . $e->getMessage());
        return false;
    }
}

// 清洁 URL 路由解析
function parseRoutePath() {
    $uri = $_SERVER['REQUEST_URI'] ?? '/';
    $path = parse_url($uri, PHP_URL_PATH) ?: '/';
    $segments = array_values(array_filter(explode('/', $path), function ($s) { return $s !== ''; }));
    return $segments;
}

// CP OAuth（https://www.cpoauth.com/）
function cpoauthCallbackUrl(): string {
    if (defined('CPOAUTH_REDIRECT_URI') && CPOAUTH_REDIRECT_URI !== '') {
        return rtrim(CPOAUTH_REDIRECT_URI, '/');
    }
    $scheme = 'http';
    if (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') {
        $scheme = 'https';
    } elseif (!empty($_SERVER['HTTP_X_FORWARDED_PROTO'])) {
        $scheme = strtolower(explode(',', $_SERVER['HTTP_X_FORWARDED_PROTO'])[0]);
    }
    $host = $_SERVER['HTTP_X_FORWARDED_HOST'] ?? ($_SERVER['HTTP_HOST'] ?? 'localhost');
    $host = trim(explode(',', $host)[0]);
    return $scheme . '://' . $host . '/cpoauth/callback';
}

// 发起 CP OAuth 授权（重定向到 cpoauth.com 授权页）
function cpoauthInitiate(string $mode = 'login'): void {
    if (!defined('CPOAUTH_CLIENT_ID')) {
        $_SESSION['error'] = 'CP OAuth 未配置';
        header('Location: /login');
        exit;
    }
    $state = bin2hex(random_bytes(16));
    $_SESSION['cpoauth_state'] = $state;
    $_SESSION['cpoauth_mode'] = $mode;
    $params = http_build_query([
        'client_id'     => CPOAUTH_CLIENT_ID,
        'redirect_uri'  => cpoauthCallbackUrl(),
        'response_type' => 'code',
        'scope'         => CPOAUTH_SCOPE,
        'state'         => $state,
    ]);
    header('Location: ' . CPOAUTH_AUTHORIZE_URL . '?' . $params);
    exit;
}

// 用授权码换取 access_token
function cpoauthExchangeCode(string $code): ?array {
    $redirectUri = cpoauthCallbackUrl();
    $payload = http_build_query([
        'grant_type'    => 'authorization_code',
        'code'          => $code,
        'redirect_uri'  => $redirectUri,
        'client_id'     => CPOAUTH_CLIENT_ID,
        'client_secret' => CPOAUTH_CLIENT_SECRET,
    ]);
    $ctx = stream_context_create([
        'http' => [
            'method'  => 'POST',
            'header'  => "Content-Type: application/x-www-form-urlencoded\r\nAccept: application/json\r\n",
            'content' => $payload,
            'timeout' => 20,
            'ignore_errors' => true,
        ],
        'ssl' => ['verify_peer' => true, 'verify_peer_name' => true],
    ]);
    $raw = @file_get_contents(CPOAUTH_TOKEN_URL, false, $ctx);
    if ($raw === false) {
        error_log('[CP OAuth] token 请求失败：file_get_contents 返回 false。redirect_uri=' . $redirectUri);
        return ['error' => 'network_error', 'error_description' => '无法连接到 CP OAuth 服务器'];
    }
    $data = json_decode($raw, true);
    if (!is_array($data)) {
        error_log('[CP OAuth] token 响应解析失败：' . substr($raw, 0, 500));
        return ['error' => 'parse_error', 'error_description' => 'CP OAuth 返回了无法解析的响应：' . substr($raw, 0, 200)];
    }
    if (empty($data['access_token'])) {
        error_log('[CP OAuth] token 获取失败：' . substr($raw, 0, 500) . ' | redirect_uri=' . $redirectUri);
    }
    return $data;
}

// 用 access_token 获取用户信息
function cpoauthGetUserInfo(string $accessToken): ?array {
    $ctx = stream_context_create([
        'http' => [
            'method'  => 'GET',
            'header'  => "Authorization: Bearer {$accessToken}\r\nAccept: application/json\r\n",
            'timeout' => 15,
            'ignore_errors' => true,
        ],
        'ssl' => ['verify_peer' => true, 'verify_peer_name' => true],
    ]);
    $raw = @file_get_contents(CPOAUTH_USERINFO_URL, false, $ctx);
    if ($raw === false) {
        error_log('[CP OAuth] userinfo 请求失败：file_get_contents 返回 false');
        return null;
    }
    $data = json_decode($raw, true);
    if (!is_array($data)) {
        error_log('[CP OAuth] userinfo 响应解析失败：' . substr($raw, 0, 500));
        return null;
    }
    return $data;
}

// 处理 CP OAuth 回调（登录或绑定）
function cpoauthHandleCallback(): void {
    $error = $_GET['error'] ?? '';
    $code = $_GET['code'] ?? '';
    $state = $_GET['state'] ?? '';

    if ($error) {
        $_SESSION['error'] = 'CP OAuth 授权失败：' . htmlspecialchars($error);
        cpoauthRedirectAfter();
    }
    if (!$code || !$state) {
        $_SESSION['error'] = 'CP OAuth 回调参数缺失';
        cpoauthRedirectAfter();
    }
    $savedState = $_SESSION['cpoauth_state'] ?? '';
    if (!$savedState || !hash_equals($savedState, $state)) {
        error_log('[CP OAuth] state 校验失败（CSRF 防护）');
        $_SESSION['error'] = 'CP OAuth 状态校验失败（CSRF 防护）';
        cpoauthRedirectAfter();
    }

    $tokenData = cpoauthExchangeCode($code);
    $accessToken = $tokenData['access_token'] ?? '';
    if (!$accessToken) {
        $errCode = $tokenData['error'] ?? 'unknown';
        $errDesc = $tokenData['error_description'] ?? $tokenData['message'] ?? '';
        $detail = $errCode;
        if ($errDesc) $detail .= '：' . $errDesc;
        $_SESSION['error'] = 'CP OAuth 获取令牌失败（' . $detail . '）';
        cpoauthRedirectAfter();
    }

    $userInfo = cpoauthGetUserInfo($accessToken);
    $cpId = (string)($userInfo['sub'] ?? '');
    $cpUsername = (string)($userInfo['username'] ?? ($userInfo['display_name'] ?? ''));
    if ($cpId === '') {
        $_SESSION['error'] = 'CP OAuth 未返回用户标识';
        cpoauthRedirectAfter();
    }

    $db = getDB();
    $mode = $_SESSION['cpoauth_mode'] ?? 'login';
    unset($_SESSION['cpoauth_state'], $_SESSION['cpoauth_mode']);

    if ($mode === 'bind') {
        $user = getCurrentUser();
        if (!$user) {
            $_SESSION['error'] = '请先登录后再绑定 CP OAuth';
            header('Location: /login'); exit;
        }
        $chk = $db->prepare("SELECT id FROM users WHERE cpoauth_id = ? AND id != ?");
        $chk->execute([$cpId, $user['id']]);
        if ($chk->fetch()) {
            $_SESSION['error'] = '此 CP OAuth 账号已绑定其他用户';
            header('Location: /profile?tab=binding'); exit;
        }
        $db->prepare("UPDATE users SET cpoauth_id = ?, cpoauth_username = ?, cpoauth_bound_at = NOW() WHERE id = ?")
            ->execute([$cpId, $cpUsername, $user['id']]);
        clearUserCache($user['id']);
        logOperation('cpoauth_bind', 'user', $user['id']);
        $_SESSION['success'] = 'CP OAuth 账号绑定成功（' . htmlspecialchars($cpUsername) . '）';
        header('Location: /profile?tab=binding'); exit;
    } else {
        $stmt = $db->prepare("SELECT id, banned FROM users WHERE cpoauth_id = ? LIMIT 1");
        $stmt->execute([$cpId]);
        $row = $stmt->fetch(PDO::FETCH_ASSOC);
        if (!$row) {
            $_SESSION['error'] = '此 CP OAuth 账号未绑定本站用户，请先注册并在安全设置中绑定。';
            header('Location: /login'); exit;
        }
        if (!empty($row['banned'])) {
            $_SESSION['error'] = '账号已被封禁';
            header('Location: /login'); exit;
        }
        $db->prepare("UPDATE users SET cpoauth_username = ?, last_activity = NOW(), last_ip = ? WHERE id = ?")
            ->execute([$cpUsername, ($_SERVER['REMOTE_ADDR'] ?? ''), $row['id']]);
        clearUserCache($row['id']);
        $_SESSION['user_id'] = (int)$row['id'];
        session_regenerate_id(true);
        logOperation('cpoauth_login', 'user', $row['id']);
        $_SESSION['success'] = '已通过 CP OAuth 登录';
        header('Location: /'); exit;
    }
}

// 回调失败后的统一跳转
function cpoauthRedirectAfter(): void {
    $mode = $_SESSION['cpoauth_mode'] ?? 'login';
    unset($_SESSION['cpoauth_state'], $_SESSION['cpoauth_mode']);
    header('Location: ' . ($mode === 'bind' ? '/profile?tab=binding' : '/login'));
    exit;
}

// 解绑 CP OAuth
function cpoauthUnbind(): void {
    $user = getCurrentUser();
    if (!$user) { $_SESSION['error'] = '请先登录'; header('Location: /login'); exit; }
    $db = getDB();
    $db->prepare("UPDATE users SET cpoauth_id = '', cpoauth_username = '', cpoauth_bound_at = NULL WHERE id = ?")
        ->execute([$user['id']]);
    clearUserCache($user['id']);
    logOperation('cpoauth_unbind', 'user', $user['id']);
    $_SESSION['success'] = 'CP OAuth 账号已解绑';
    header('Location: /profile?tab=binding');
    exit;
}

// 题目（Problems）：确保 problems / problem_submissions / problem_testcases 表存在并补齐缺失字段
function ensureProblemsTables(): void {
    $db = getDB();
    $addColumnIfMissing = function ($table, $col, $def) use ($db) {
        if (!columnExists($table, $col)) {
            try {
                $db->exec("ALTER TABLE `{$table}` ADD COLUMN {$col} {$def}");
                cacheClear("col_exists_{$table}_{$col}");
            } catch (PDOException $e) {
                error_log('[ensureProblemsTables] addColumn ' . $table . '.' . $col . ' failed: ' . $e->getMessage());
            }
        }
    };
    if (!tableExists('problems')) {
        try {
            $db->exec("CREATE TABLE IF NOT EXISTS problems (
                id INT AUTO_INCREMENT PRIMARY KEY,
                title VARCHAR(200) NOT NULL,
                description MEDIUMTEXT NOT NULL,
                input_format TEXT DEFAULT '',
                output_format TEXT DEFAULT '',
                sample_input TEXT DEFAULT '',
                sample_output TEXT DEFAULT '',
                hint TEXT DEFAULT '',
                time_limit INT DEFAULT 1000,
                memory_limit INT DEFAULT 256,
                tags VARCHAR(200) DEFAULT '',
                difficulty VARCHAR(30) DEFAULT '入门',
                source VARCHAR(100) DEFAULT '',
                visible TINYINT(1) DEFAULT 1,
                created_by INT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
                INDEX idx_difficulty (difficulty),
                INDEX idx_visible (visible),
                INDEX idx_created_at (created_at),
                INDEX idx_created_by (created_by)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci");
            cacheClear("table_exists_problems");
        } catch (PDOException $e) {
            error_log('[ensureProblemsTables] create problems failed: ' . $e->getMessage());
        }
    }
    // 旧表字段补齐
    $addColumnIfMissing('problems', 'description', "MEDIUMTEXT NOT NULL");
    $addColumnIfMissing('problems', 'input_format', "TEXT DEFAULT ''");
    $addColumnIfMissing('problems', 'output_format', "TEXT DEFAULT ''");
    $addColumnIfMissing('problems', 'sample_input', "TEXT DEFAULT ''");
    $addColumnIfMissing('problems', 'sample_output', "TEXT DEFAULT ''");
    $addColumnIfMissing('problems', 'hint', "TEXT DEFAULT ''");
    $addColumnIfMissing('problems', 'time_limit', "INT DEFAULT 1000");
    $addColumnIfMissing('problems', 'memory_limit', "INT DEFAULT 256");
    $addColumnIfMissing('problems', 'tags', "VARCHAR(200) DEFAULT ''");
    $addColumnIfMissing('problems', 'difficulty', "VARCHAR(30) DEFAULT NULL");
    $addColumnIfMissing('problems', 'source', "VARCHAR(100) DEFAULT ''");
    $addColumnIfMissing('problems', 'visible', "TINYINT(1) DEFAULT 1");
    $addColumnIfMissing('problems', 'created_by', "INT NOT NULL DEFAULT 0");
    $addColumnIfMissing('problems', 'updated_at', "DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP");

    if (!tableExists('problem_submissions')) {
        try {
            $db->exec("CREATE TABLE IF NOT EXISTS problem_submissions (
                id INT AUTO_INCREMENT PRIMARY KEY,
                problem_id INT NOT NULL,
                user_id INT NOT NULL,
                code MEDIUMTEXT NOT NULL,
                language VARCHAR(30) DEFAULT 'cpp',
                status VARCHAR(20) DEFAULT 'pending',
                score INT DEFAULT 0,
                time_used INT DEFAULT 0,
                memory_used INT DEFAULT 0,
                error_message TEXT DEFAULT '',
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                INDEX idx_problem_id (problem_id),
                INDEX idx_user_id (user_id),
                INDEX idx_status (status),
                INDEX idx_created_at (created_at)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci");
            cacheClear("table_exists_problem_submissions");
        } catch (PDOException $e) {
            error_log('[ensureProblemsTables] create problem_submissions failed: ' . $e->getMessage());
        }
    }
    $addColumnIfMissing('problem_submissions', 'problem_id', "INT NOT NULL DEFAULT 0");
    $addColumnIfMissing('problem_submissions', 'user_id', "INT NOT NULL DEFAULT 0");
    $addColumnIfMissing('problem_submissions', 'code', "MEDIUMTEXT NOT NULL");
    $addColumnIfMissing('problem_submissions', 'language', "VARCHAR(30) DEFAULT 'cpp'");
    $addColumnIfMissing('problem_submissions', 'status', "VARCHAR(20) DEFAULT 'pending'");
    $addColumnIfMissing('problem_submissions', 'score', "INT DEFAULT 0");
    $addColumnIfMissing('problem_submissions', 'time_used', "INT DEFAULT 0");
    $addColumnIfMissing('problem_submissions', 'memory_used', "INT DEFAULT 0");
    $addColumnIfMissing('problem_submissions', 'error_message', "TEXT DEFAULT ''");

    // 题目测试点表
    if (!tableExists('problem_testcases')) {
        try {
            $db->exec("CREATE TABLE IF NOT EXISTS problem_testcases (
                id INT AUTO_INCREMENT PRIMARY KEY,
                problem_id INT NOT NULL,
                name VARCHAR(100) DEFAULT '',
                input_file VARCHAR(255) NOT NULL DEFAULT '',
                output_file VARCHAR(255) NOT NULL DEFAULT '',
                is_sample TINYINT(1) DEFAULT 0,
                score INT DEFAULT 0,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                INDEX idx_problem_id (problem_id)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE utf8mb4_unicode_ci");
            cacheClear("table_exists_problem_testcases");
        } catch (PDOException $e) {
            error_log('[ensureProblemsTables] create problem_testcases failed: ' . $e->getMessage());
        }
    }
    $addColumnIfMissing('problem_testcases', 'problem_id', "INT NOT NULL DEFAULT 0");
    $addColumnIfMissing('problem_testcases', 'name', "VARCHAR(100) DEFAULT ''");
    $addColumnIfMissing('problem_testcases', 'input_file', "VARCHAR(255) NOT NULL DEFAULT ''");
    $addColumnIfMissing('problem_testcases', 'output_file', "VARCHAR(255) NOT NULL DEFAULT ''");
    $addColumnIfMissing('problem_testcases', 'is_sample', "TINYINT(1) DEFAULT 0");
    $addColumnIfMissing('problem_testcases', 'score', "INT DEFAULT 0");

    // 字符集转换：仅在表非新建且本请求首次执行时做一次
    static $charsetConverted = false;
    if (!$charsetConverted) {
        try {
            $db->exec("ALTER TABLE problems CONVERT TO CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
        } catch (PDOException $e) {
            error_log('[ensureProblemsTables] convert problems charset failed: ' . $e->getMessage());
        }
        try {
            $db->exec("ALTER TABLE problem_submissions CONVERT TO CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
        } catch (PDOException $e) {
            error_log('[ensureProblemsTables] convert problem_submissions charset failed: ' . $e->getMessage());
        }
        try {
            $db->exec("ALTER TABLE problem_testcases CONVERT TO CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
        } catch (PDOException $e) {
            error_log('[ensureProblemsTables] convert problem_testcases charset failed: ' . $e->getMessage());
        }
        $charsetConverted = true;
    }
}

// 获取题目的所有测试点（按 id 升序）
function getProblemTestcases(int $problem_id): array {
    if ($problem_id <= 0) return [];
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT * FROM problem_testcases WHERE problem_id = ? ORDER BY id ASC LIMIT 200");
        $stmt->execute([$problem_id]);
        return $stmt->fetchAll(PDO::FETCH_ASSOC);
    } catch (PDOException $e) {
        error_log('[getProblemTestcases] failed: ' . $e->getMessage());
        return [];
    }
}

// 测试点文件存储目录
function testcaseDir(int $problem_id): string {
    return __DIR__ . '/uploads/testcases/' . $problem_id;
}

// 删除测试点（含数据库记录和物理文件）
function deleteTestcase(int $testcase_id): array {
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT * FROM problem_testcases WHERE id = ?");
        $stmt->execute([$testcase_id]);
        $tc = $stmt->fetch(PDO::FETCH_ASSOC);
        if (!$tc) {
            return ['success' => false, 'message' => '测试点不存在'];
        }
        $db->prepare("DELETE FROM problem_testcases WHERE id = ?")->execute([$testcase_id]);
        foreach (['input_file', 'output_file'] as $field) {
            $rel = $tc[$field] ?? '';
            if ($rel !== '') {
                $abs = __DIR__ . '/' . $rel;
                if (is_file($abs) && !@unlink($abs)) {
                    error_log('[deleteTestcase] unlink 失败：' . $abs);
                }
            }
        }
        return ['success' => true, 'message' => '测试点已删除'];
    } catch (PDOException $e) {
        error_log('[deleteTestcase] tcid=' . $testcase_id . ' ' . $e->getMessage());
        return ['success' => false, 'message' => '删除失败，请稍后重试'];
    }
}

// 按 ID 获取题目（带内存缓存）
function getProblemById($id) {
    $id = (int)$id;
    if ($id <= 0) return [];
    $cacheKey = 'problem_' . $id;
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;
    $db = getDB();
    try {
        $stmt = $db->prepare("SELECT * FROM problems WHERE id = ?");
        $stmt->execute([$id]);
        return cacheSet($cacheKey, $stmt->fetch(PDO::FETCH_ASSOC) ?: []);
    } catch (PDOException $e) {
        error_log('[getProblemById] failed: ' . $e->getMessage());
        return [];
    }
}

function clearProblemCache($id) {
    cacheClear('problem_' . (int)$id);
}

// 难度配色
function getDifficultyColor(string $difficulty): string {
    $map = [
        '简单' => '#10b981',
        '中等' => '#f59e0b',
        '困难' => '#ef4444',
    ];
    return $map[$difficulty] ?? '#808080';
}

// 难度对应的点亮格数（1-5）
function getDifficultyLevel(string $difficulty): int {
    $map = [
        '简单' => 1,
        '中等' => 3,
        '困难' => 5,
    ];
    return $map[$difficulty] ?? 1;
}

// 渲染难度条（5 个圆点）
function renderDifficultyBar(string $difficulty): string {
    $color = getDifficultyColor($difficulty);
    $level = getDifficultyLevel($difficulty);
    $html = '<span class="diff-bar" style="color:' . $color . ';">';
    for ($i = 1; $i <= 5; $i++) {
        $html .= '<span class="dot' . ($i <= $level ? ' on' : '') . '"></span>';
    }
    $html .= '<span class="diff-label">' . htmlspecialchars($difficulty) . '</span></span>';
    return $html;
}

// 渲染难度彩色 pill 徽章（8 档难度）
function renderDifficultyPill(string $difficulty): string {
    $difficulty = $difficulty ?: '入门';
    $map = [
        '入门' => 1, '普及-' => 2, '普及' => 3, '普及+/提高-' => 4,
        '提高' => 5, '提高+/省选-' => 6, '省选/NOI-' => 7, 'NOI/NOI+/CTS' => 8,
        '简单' => 1, '中等' => 4, '困难' => 7,
    ];
    $lvl = $map[$difficulty] ?? 1;
    return '<span class="diff-pill diff-pill-' . $lvl . '">' . htmlspecialchars($difficulty) . '</span>';
}

// 提交状态中文标签
function getSubmissionStatusLabel(string $status): string {
    $map = [
        'pending'   => '等待评测',
        'judging'   => '评测中',
        'accepted'  => '通过',
        'wrong'     => '答案错误',
        'tle'       => '超时',
        'mle'       => '内存超限',
        're'        => '运行错误',
        'ce'        => '编译错误',
    ];
    return $map[$status] ?? $status;
}

// 提交状态颜色
function getSubmissionStatusColor(string $status): string {
    $map = [
        'pending'   => '#6b7280',
        'judging'   => '#3b82f6',
        'accepted'  => '#10b981',
        'wrong'     => '#ef4444',
        'tle'       => '#f59e0b',
        'mle'       => '#f59e0b',
        're'        => '#ef4444',
        'ce'        => '#8b5cf6',
    ];
    return $map[$status] ?? '#808080';
}

