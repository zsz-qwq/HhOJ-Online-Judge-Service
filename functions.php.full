function getPageTitle($page, $first = '') {
    $titles = [
        'home'             => '首页',
        'login'            => '登录',
        'register'         => '注册',
        'forum'            => '讨论区',
        'forum_post'       => '帖子详情',
        'articles'         => '专栏',
        'article'          => '文章详情',
        'write_article'    => '撰写文章',
        'votes'            => '投票',
        'vote_detail'      => '投票详情',
        'tickets'          => '工单',
        'ticket'           => '工单详情',
        'users'            => '用户',
        'user'             => '用户主页',
        'profile'          => '个人设置',
        'benben'           => '犇犇',
        'taopian'          => '陶片',
        'station'          => '站务',
        'station_post'     => '站务详情',
        'messages'         => '私信',
        'notifications'    => '通知',
        'search'           => '搜索',
        'rules'            => '社区规则',
        'updates'          => '更新简介',
        'favorites'        => '收藏',
        'forgot_password'  => '找回密码',
        'banned'           => '账号封禁',
        'login_required'   => '需要登录',
        'cpoauth_callback' => 'CP OAuth',
    ];
    if ($page === 'home' || $first === '' || $first === 'index') {
        return '首页 - ' . SITE_NAME;
    }
    $name = $titles[$page] ?? ($titles[$first] ?? '');
    if ($name === '') {
        return SITE_NAME;
    }
    return $name . ' - ' . SITE_NAME;
}

// 简单缓存：APCu 跨请求 + 请求内 static 双层
function &_cacheStore() {
    static $cache = [];
    return $cache;
}
function cacheGet($key) {
    $cache = &_cacheStore();
    if (array_key_exists($key, $cache)) return $cache[$key];
    if (function_exists('apcu_fetch') && apcu_exists($key)) {
        $ok = false;
        $v = apcu_fetch($key, $ok);
        if ($ok) { $cache[$key] = $v; return $v; }
    }
    return null;
}
function cacheSet($key, $value, int $ttl = 0) {
    $cache = &_cacheStore();
    $cache[$key] = $value;
    if (function_exists('apcu_store') && $ttl > 0) {
        apcu_store($key, $value, $ttl);
    }
    return $value;
}
function cacheClear($key = null) {
    $cache = &_cacheStore();
    if ($key === null) {
        $cache = [];
        if (function_exists('apcu_clear_cache')) apcu_clear_cache();
        return;
    }
    unset($cache[$key]);
    if (function_exists('apcu_delete')) apcu_delete($key);
}

function isCaptchaVerified($ttlSeconds = 300) {
    if (empty($_SESSION['captcha_verified_at'])) return false;
    return time() - (int)$_SESSION['captcha_verified_at'] < $ttlSeconds;
}
function consumeCaptchaVerification() {
    unset($_SESSION['captcha_verified_at']);
}

// CSRF Token（7 天有效期，匹配 session 生命周期，避免长开 tab 后过期）
function generateCsrfToken(): string {
    if (session_status() !== PHP_SESSION_ACTIVE) return '';
    $now = time();
    if (empty($_SESSION['csrf_token'])) {
        $_SESSION['csrf_token'] = bin2hex(random_bytes(16));
        $_SESSION['csrf_token_expires'] = $now + 86400 * 7;
    } elseif (!empty($_SESSION['csrf_token_expires']) && $_SESSION['csrf_token_expires'] < $now) {
        $_SESSION['csrf_token'] = bin2hex(random_bytes(16));
        $_SESSION['csrf_token_expires'] = $now + 86400 * 7;
    }
    return $_SESSION['csrf_token'];
}
function csrfTokenField(): string {
    $t = generateCsrfToken();
    if ($t === '') return '';
    return '<input type="hidden" name="csrf_token" value="' . htmlspecialchars($t, ENT_QUOTES, 'UTF-8') . '">';
}
function verifyCsrfToken(?string $token = null): bool {
    if (session_status() !== PHP_SESSION_ACTIVE) return false;
    if (empty($_SESSION['csrf_token'])) return false;
    // 过期检查（容错：1 小时内的过期 token 仍接受，避免边界场景失效）
    if (!empty($_SESSION['csrf_token_expires'])) {
        $expired = $_SESSION['csrf_token_expires'] < time();
        $tooOld = $_SESSION['csrf_token_expires'] < time() - 3600;
        if ($tooOld) {
            error_log('[CSRF] token 已严重过期（>1h）');
            return false;
        }
        // 1 小时内过期：自动续期并接受
        if ($expired) {
            $_SESSION['csrf_token_expires'] = time() + 86400 * 7;
        }
    }
    if ($token === null) {
        $token = $_POST['csrf_token'] ?? ($_SERVER['HTTP_X_CSRF_TOKEN'] ?? '');
    }
    if (!is_string($token) || $token === '') return false;
    return hash_equals($_SESSION['csrf_token'], $token);
}
// Origin / Referer 校验，AJAX 端点兜底
function verifyRequestOrigin(): bool {
    $host = $_SERVER['HTTP_HOST'] ?? '';
    if ($host === '') return false;
    $origin = $_SERVER['HTTP_ORIGIN'] ?? '';
    $referer = $_SERVER['HTTP_REFERER'] ?? '';
    $expected = (($_SERVER['HTTPS'] ?? '') === 'on' ? 'https://' : 'http://') . $host;
    if ($origin !== '') {
        return strncmp($origin, $expected, strlen($expected)) === 0;
    }
    if ($referer !== '') {
        return strncmp($referer, $expected, strlen($expected)) === 0;
    }
    return false;
}

// 限流：APCu 滑动窗口，无 APCu 时回退到 session
function rateLimit(string $key, int $max, int $window): bool {
    if ($max <= 0 || $window <= 0) return true;
    if (function_exists('apcu_inc')) {
        $fullKey = 'rl_' . $key;
        $cur = apcu_inc($fullKey, 1, $found);
        if (!$found) {
            apcu_store($fullKey, 1, $window);
            $cur = 1;
        }
        return $cur <= $max;
    }
    if (session_status() !== PHP_SESSION_ACTIVE) return true;
    $sk = '_rl_' . $key;
    $now = time();
    $arr = $_SESSION[$sk] ?? [];
    if (!is_array($arr)) $arr = [];
    $arr = array_values(array_filter($arr, function ($t) use ($now, $window) { return $t > $now - $window; }));
    if (count($arr) >= $max) {
        $_SESSION[$sk] = $arr;
        return false;
    }
    $arr[] = $now;
    $_SESSION[$sk] = $arr;
    return true;
}
function rateLimitByIp(string $action, int $max, int $window): bool {
    $ip = getUserIP();
    return rateLimit('ip_' . $action . '_' . $ip, $max, $window);
}
function rateLimitByUser(string $action, int $max, int $window): bool {
    $uid = $_SESSION['user_id'] ?? 0;
    if ($uid > 0) {
        return rateLimit('u_' . $action . '_' . $uid, $max, $window);
    }
    $sid = session_id() ?: 'anon';
    return rateLimit('s_' . $action . '_' . $sid, $max, $window);
}
function rateLimitRemaining(string $key, int $max, int $window): int {
    if (function_exists('apcu_fetch') && apcu_exists('rl_' . $key)) {
        $v = apcu_fetch('rl_' . $key, $ok);
        if ($ok) return max(0, $max - (int)$v);
    }
    return $max;
}
function rateLimitExceededResponse(string $action = '请求', int $retry = 60) {
    http_response_code(429);
    header('Retry-After: ' . $retry);
    header('Content-Type: application/json; charset=utf-8');
    echo json_encode(['success' => false, 'message' => '操作过于频繁，请稍后再试（' . $action . '）']);
    exit;
}

// 全局熔断：1 秒内 > 30 次请求 → 触发 60 秒
function globalCircuitBreaker(string $ip): void {
    if ($ip === '' || $ip === '0.0.0.0') return;
    if (!function_exists('apcu_inc')) return;
    $cbKey = 'cb_' . $ip;
    if (apcu_exists('cb_lock_' . $ip)) {
        $lockExp = (int)apcu_fetch('cb_lock_' . $ip, $ok);
        if ($ok && $lockExp > time()) {
            http_response_code(429);
            header('Retry-After: ' . max(1, $lockExp - time()));
            header('Content-Type: text/html; charset=utf-8');
            echo '<!DOCTYPE html><html><head><meta charset="utf-8"><title>请求过于频繁</title></head><body style="font-family:system-ui;background:#0f1020;color:#e5e7eb;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0"><div style="text-align:center;padding:2rem;border-radius:12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);max-width:480px"><h2 style="margin:0 0 .5rem;color:#f59e0b">请求过于频繁</h2><p style="margin:0;color:#9ca3af">系统检测到您的访问频率异常，已暂时限制访问。请稍后再试。</p></div></body></html>';
            exit;
        }
        apcu_delete('cb_lock_' . $ip);
    }
    $cur = apcu_inc($cbKey, 1, $found);
    if (!$found) {
        apcu_store($cbKey, 1, 1);
        $cur = 1;
    }
    if ($cur > 30) {
        apcu_store('cb_lock_' . $ip, time() + 60, 60);
        apcu_delete($cbKey);
        try {
            $db = getDB();
            $db->prepare("INSERT IGNORE INTO banned_ips (ip, reason, created_by, expires_at) VALUES (?, ?, NULL, ?)")
               ->execute([$ip, '自动熔断：1秒内请求超过30次', date('Y-m-d H:i:s', time() + 60)]);
        } catch (Throwable $e) {
            error_log('[globalCircuitBreaker] insert banned_ips failed: ' . $e->getMessage());
        }
        cacheClear('ip_banned_' . $ip);
        http_response_code(429);
        header('Retry-After: 60');
        header('Content-Type: text/html; charset=utf-8');
        echo '<!DOCTYPE html><html><head><meta charset="utf-8"><title>请求过于频繁</title></head><body style="font-family:system-ui;background:#0f1020;color:#e5e7eb;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0"><div style="text-align:center;padding:2rem;border-radius:12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);max-width:480px"><h2 style="margin:0 0 .5rem;color:#ef4444">触发熔断</h2><p style="margin:0;color:#9ca3af">您在短时间内发起大量请求，已被临时限制访问 60 秒。</p></div></body></html>';
        exit;
    }
}

// 登录失败计数：IP 维度 5 分钟 10 次 → 封 30 分钟；账号维度 5 分钟 5 次 → 锁 15 分钟
function recordLoginFailure(string $username, string $ip): void {
    $t = time();
    if (!function_exists('apcu_inc')) return;
    $k1 = 'lf_ip_' . $ip;
    $c1 = apcu_inc($k1, 1, $f);
    if (!$f) { apcu_store($k1, 1, 300); $c1 = 1; }
    if ($c1 >= 10) {
        try {
            $db = getDB();
            $db->prepare("INSERT IGNORE INTO banned_ips (ip, reason, created_by, expires_at) VALUES (?, ?, NULL, ?)")
               ->execute([$ip, '登录失败次数过多（' . $username . '）', date('Y-m-d H:i:s', $t + 1800)]);
        } catch (Throwable $e) {
            error_log('[recordLoginFailure] insert banned_ips failed: ' . $e->getMessage());
        }
        cacheClear('ip_banned_' . $ip);
        apcu_delete($k1);
    }
    $k2 = 'lf_u_' . md5($username);
    $c2 = apcu_inc($k2, 1, $f2);
    if (!$f2) { apcu_store($k2, 1, 300); $c2 = 1; }
    if ($c2 >= 5) {
        apcu_store('lf_lock_' . md5($username), $t + 900, 900);
        apcu_delete($k2);
    }
}
function isAccountLocked(string $username): bool {
    if (!function_exists('apcu_fetch')) return false;
    $v = apcu_fetch('lf_lock_' . md5($username), $ok);
    if (!$ok) return false;
    if ((int)$v < time()) {
        apcu_delete('lf_lock_' . md5($username));
        return false;
    }
    return true;
}
function clearLoginFailure(string $username): void {
    if (function_exists('apcu_delete')) {
        apcu_delete('lf_u_' . md5($username));
        apcu_delete('lf_lock_' . md5($username));
    }
}

// 用户每日活动限额：返回 [已用, 上限]
function getUserDailyUsage(int $userId, string $action): array {
    if ($userId <= 0) return [0, 0];
    $limits = [
        'forum_post'   => 30,
        'forum_reply'  => 100,
        'station_post' => 20,
        'benben_post'  => 50,
        'article'      => 10,
        'message'      => 100,
        'ticket'       => 10,
        'submission'   => 200,
    ];
    $max = $limits[$action] ?? 0;
    if ($max <= 0) return [0, 0];
    $cacheKey = 'daily_' . $action . '_' . $userId . '_' . date('Ymd');
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return [(int)$cached, $max];
    $used = 0;
    try {
        $db = getDB();
        $stmt = $db->prepare("SELECT count FROM daily_activity_log WHERE user_id = ? AND action = ? AND date = CURDATE()");
        $stmt->execute([$userId, $action]);
        $row = $stmt->fetch(PDO::FETCH_ASSOC);
        $used = $row ? (int)$row['count'] : 0;
    } catch (Throwable $e) {
        error_log('[getUserDailyUsage] failed: ' . $e->getMessage());
    }
    cacheSet($cacheKey, $used, 300);
    return [$used, $max];
}
function incrementUserDailyUsage(int $userId, string $action, int $delta = 1): void {
    if ($userId <= 0 || $delta <= 0) return;
    $cacheKey = 'daily_' . $action . '_' . $userId . '_' . date('Ymd');
    try {
        $db = getDB();
        $db->prepare("INSERT INTO daily_activity_log (user_id, action, date, count) VALUES (?, ?, CURDATE(), ?)
                      ON DUPLICATE KEY UPDATE count = count + VALUES(count)")
           ->execute([$userId, $action, $delta]);
    } catch (Throwable $e) {
        error_log('[incrementUserDailyUsage] failed: ' . $e->getMessage());
    }
    $cached = cacheGet($cacheKey);
    if ($cached !== null) cacheSet($cacheKey, (int)$cached + $delta, 300);
    else cacheSet($cacheKey, $delta, 300);
}
function checkUserDailyLimit(int $userId, string $action): bool {
    [$used, $max] = getUserDailyUsage($userId, $action);
    if ($max <= 0) return true;
    return $used < $max;
}

function safe_substr($str, $start, $length = null) {
    if (function_exists('mb_substr')) {
        return mb_substr($str, $start, $length, 'UTF-8');
    }
    return substr($str, $start, $length);
}

// 将相对路径规范化为站点根的绝对路径，避免在详情页（如 /discuss/123）下被浏览器错误解析
function assetUrl($u) {
    if ($u === null || $u === '') return '';
    $u = trim($u);
    if ($u === '') return '';
    if (preg_match('#^(https?:)?//#i', $u)) return $u;
    if (stripos($u, 'data:') === 0) return $u;
    if (strpos($u, '#') === 0) return $u;
    if (stripos($u, 'mailto:') === 0) return $u;
    if (stripos($u, 'javascript:') === 0) return '';
    if (strpos($u, '/') === 0) return $u;
    return '/' . ltrim($u, '/');
}

// 安全重定向路径校验：防止开放重定向
function safeRedirectPath(string $path, string $fallback = '/index'): string {
    if (strpos($fallback, '/') !== 0 || strpos($fallback, '//') === 0 || strpos($fallback, '/\\') === 0) {
        $fallback = '/index';
    }
    if ($path === '') return $fallback;
    if (strpos($path, '/') !== 0) return $fallback;
    if (strpos($path, '//') === 0 || strpos($path, '/\\') === 0) return $fallback;
    if (strpbrk($path, "\r\n") !== false) return $fallback;
    if (preg_match('#^[a-zA-Z][a-zA-Z0-9+.\-]*:#', $path)) return $fallback;
    return $path;
}

// 安全图片上传校验：扩展名白名单 + finfo_file MIME + GD 真图验证
function validateImageUpload(string $tmpName, string $origName, int $maxSize = 2097152): array {
    if (!is_uploaded_file($tmpName)) {
        return ['ok' => false, 'ext' => '', 'error' => '非法的上传文件'];
    }
    $fileSize = filesize($tmpName);
    if ($fileSize === false || $fileSize <= 0) {
        return ['ok' => false, 'ext' => '', 'error' => '文件为空'];
    }
    if ($fileSize > $maxSize) {
        return ['ok' => false, 'ext' => '', 'error' => '文件大小超过限制'];
    }
    $ext = strtolower(pathinfo($origName, PATHINFO_EXTENSION));
    $allowedExt = ['jpg', 'jpeg', 'png', 'gif', 'webp'];
    if (!in_array($ext, $allowedExt, true)) {
        return ['ok' => false, 'ext' => '', 'error' => '仅支持 JPG/PNG/GIF/WebP 格式'];
    }
    if (function_exists('finfo_open')) {
        $finfo = finfo_open(FILEINFO_MIME_TYPE);
        if ($finfo) {
            $mime = finfo_file($finfo, $tmpName);
            finfo_close($finfo);
            $allowedMime = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
            if (!in_array($mime, $allowedMime, true)) {
                return ['ok' => false, 'ext' => '', 'error' => '文件类型不允许（检测到 ' . $mime . '）'];
            }
        }
    }
    if (function_exists('getimagesize')) {
        $info = @getimagesize($tmpName);
        if ($info === false || !isset($info[2]) || $info[2] === 0) {
            return ['ok' => false, 'ext' => '', 'error' => '不是有效的图片文件'];
        }
    }
    return ['ok' => true, 'ext' => $ext, 'error' => ''];
}

// 头像 URL：有上传头像用上传的，否则生成首字母 SVG 兜底
function avatarUrl($user) {
    if (!empty($user['avatar'])) return htmlspecialchars(assetUrl($user['avatar']));
    $name = $user['username'] ?? 'U';

    $cacheKey = 'avatar_' . $name;
    $cached = cacheGet($cacheKey);
    if ($cached !== null) return $cached;

    $initial = safe_substr($name, 0, 1);
    $hash = md5($name);
    $r = hexdec(substr($hash, 0, 2));
    $g = hexdec(substr($hash, 2, 2));
    $b = hexdec(substr($hash, 4, 2));
    $max = max($r, $g, $b);
    $min = min($r, $g, $b);
    $l = ($max + $min) / 2 / 255;
    $targetL = 0.45;
    if ($l > 0.01) {
        $ratio = $targetL / $l;
        $r = min(255, max(0, (int)($r * $ratio)));
        $g = min(255, max(0, (int)($g * $ratio)));
        $b = min(255, max(0, (int)($b * $ratio)));
    }
    $bgColor = sprintf('#%02x%02x%02x', $r, $g, $b);
    $svg = '<svg xmlns="http://www.w3.org/2000/svg" width="128" height="128" viewBox="0 0 128 128">'
         . '<rect width="128" height="128" fill="' . $bgColor . '"/>'
         . '<text x="50%" y="50%" font-size="56" fill="#fff" text-anchor="middle" dominant-baseline="central" font-family="Arial,sans-serif" font-weight="600">'
         . htmlspecialchars($initial)
         . '</text></svg>';
    return cacheSet($cacheKey, 'data:image/svg+xml;base64,' . base64_encode($svg));
}
function getUserBackgroundUrl($user) {
    if (!$user || empty($user['background_image'])) return '';
    return htmlspecialchars(assetUrl($user['background_image']));
}
function icon(string $name, int $size = 20, string $class = ''): string {
    static $cache = [];
    $cacheKey = $name . '|' . $size . '|' . $class;
    if (isset($cache[$cacheKey])) return $cache[$cacheKey];

    $svg = '';
    $path = __DIR__ . '/assets/icons/' . $name . '.svg';
    if (file_exists($path)) {
        $svg = @file_get_contents($path) ?: '';
    }
    if ($svg === '') {
        $svg = icon_builtin($name);
    }
    if ($svg !== '') {
        $svg = preg_replace('/<svg/', '<svg width="' . $size . '" height="' . $size . '" class="icon ' . htmlspecialchars($class) . '"', $svg, 1);
    }
    return $cache[$cacheKey] = $svg;
}

// 内置 SVG 图标字典（Feather Icons 风格，颜色继承 currentColor）
function icon_builtin(string $name): string {
    static $dict = null;
    if ($dict !== null && isset($dict['__loaded__'])) {
        return $dict[$name] ?? '';
    }
    $p = 'xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"';
    $dict = [
        '__loaded__' => true,
        'home'         => '<svg '.$p.'><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>',
        'forum'        => '<svg '.$p.'><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>',
        'benben'       => '<svg '.$p.'><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>',
        'book-open'    => '<svg '.$p.'><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>',
        'code-square'  => '<svg '.$p.'><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><polyline points="9 9 7 12 9 15"></polyline><polyline points="15 9 17 12 15 15"></polyline></svg>',
        'scroll'       => '<svg '.$p.'><path d="M8 21h12a2 2 0 0 0 2-2v-2H10v2a2 2 0 1 1-4 0V5a2 2 0 1 0-4 0v3h4"></path><path d="M19 17V5a2 2 0 0 0-2-2H4"></path></svg>',
