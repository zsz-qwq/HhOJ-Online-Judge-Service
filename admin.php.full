            </form>
            <div class="rules-grid" id="rules-grid">
                <div class="rules-pane">
                    <div class="rules-pane-header"><span>编辑</span><span style="font-weight:400;font-size:11px;color:var(--text-muted);" id="rules-lines">0 行</span></div>
                    <div class="rules-pane-body">
                        <div id="rules-mirror" style="padding:16px;font-family:monospace;font-size:13px;color:var(--text-muted);white-space:pre-wrap;word-break:break-word;"></div>
                    </div>
                </div>
                <div class="rules-pane">
                    <div class="rules-pane-header"><span>预览</span></div>
                    <div class="rules-pane-body">
                        <div class="rules-preview post-content" id="rules-preview"><span style="color:var(--text-muted);">输入内容后显示预览...</span></div>
                    </div>
                </div>
            </div>
            <script>
                (function() {
                    var t = document.getElementById('rules-editor');
                    var counter = document.getElementById('rules-counter');
                    var linesEl = document.getElementById('rules-lines');
                    var mirror = document.getElementById('rules-mirror');
                    var preview = document.getElementById('rules-preview');
                    var grid = document.getElementById('rules-grid');
                    var debounceTimer = null;

                    function updateStats() {
                        var v = t.value || '';
                        var len = v.length;
                        counter.textContent = len + ' 字';
                        linesEl.textContent = (v ? v.split('\n').length : 0) + ' 行';
                        if (mirror) {
                            mirror.textContent = v || '（空）';
                        }
                    }
                    function renderMathAndCode(container){
                        if(window.hljs){
                            container.querySelectorAll('pre code').forEach(function(b){
                                if(!b.dataset.highlighted){ try{hljs.highlightElement(b);}catch(e){} }
                            });
                        }
                        if(window.renderMathInElement){
                            try{
                                renderMathInElement(container,{
                                    delimiters:[
                                        {left:'$$',right:'$$',display:true},
                                        {left:'$',right:'$',display:false},
                                        {left:'\\[',right:'\\]',display:true},
                                        {left:'\\(',right:'\\)',display:false}
                                    ],
                                    ignoredTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'],
                                    throwOnError:false,
                                    strict:false,
                                    trust:true,
                                    macros: {
                                        '\\R': '\\mathbb{R}', '\\N': '\\mathbb{N}', '\\Z': '\\mathbb{Z}',
                                        '\\Q': '\\mathbb{Q}', '\\C': '\\mathbb{C}',
                                        '\\vec': '\\overrightarrow{#1}', '\\mod': '\\pmod{#1}'
                                    }
                                });
                            }catch(e){}
                        }
                    }
                    // 当 hljs / katex 异步加载完成时，对当前预览重新渲染
                    window._rulesRehighlight = function(){
                        if(preview) renderMathAndCode(preview);
                    };
                    function fetchPreview() {
                        var v = t.value || '';
                        if (!v.trim()) {
                            preview.innerHTML = '<span style="color:var(--text-muted);">输入内容后显示预览...</span>';
                            return;
                        }
                        // 用 urlencoded 编码并显式带上 csrf_token + AJAX 标识，
                        // 避免 CSRF 失败时返回整页 HTML 被塞进预览容器
                        var token = window.CSRF_TOKEN || '';
                        var body = 'action=preview_markdown&content=' + encodeURIComponent(v) + '&csrf_token=' + encodeURIComponent(token);
                        fetch('/index', {
                            method: 'POST',
                            credentials: 'same-origin',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'X-Requested-With': 'XMLHttpRequest',
                                'X-CSRF-TOKEN': token
                            },
                            body: body
                        })
                            .then(function(r){
                                var ct = r.headers.get('Content-Type') || '';
                                if (ct.indexOf('application/json') !== -1) {
                                    // CSRF 失败等服务端 JSON 错误
                                    return r.json().then(function(j){
                                        preview.innerHTML = '<span style="color:var(--danger);">' + (j.message || '预览加载失败') + '</span>';
                                    });
                                }
                                return r.text();
                            })
                            .then(function(html){
                                if (typeof html !== 'string') return;
                                preview.innerHTML = html;
                                renderMathAndCode(preview);
                            })
                            .catch(function(){
                                preview.innerHTML = '<span style="color:var(--danger);">预览加载失败</span>';
                            });
                    }
                    t.addEventListener('input', function() {
                        updateStats();
                        clearTimeout(debounceTimer);
                        debounceTimer = setTimeout(fetchPreview, 400);
                    });
                    updateStats();
                    fetchPreview();

                    window.rulesInsert = function(prefix, suffix, placeholder) {
                        var s = t.selectionStart, e = t.selectionEnd;
                        var v = t.value;
                        var sel = v.substring(s, e) || placeholder;
                        t.value = v.substring(0, s) + prefix + sel + suffix + v.substring(e);
                        var pos = s + prefix.length + sel.length;
                        t.focus();
                        t.selectionStart = s + prefix.length;
                        t.selectionEnd = pos;
                        updateStats();
                        clearTimeout(debounceTimer);
                        debounceTimer = setTimeout(fetchPreview, 200);
                    };
                    window.rulesLinePrefix = function(prefix) {
                        var s = t.selectionStart, e = t.selectionEnd;
                        var v = t.value;
                        var lineStart = v.lastIndexOf('\n', s - 1) + 1;
                        t.value = v.substring(0, lineStart) + prefix + v.substring(lineStart);
                        t.focus();
                        t.selectionStart = t.selectionEnd = s + prefix.length;
                        updateStats();
                        clearTimeout(debounceTimer);
                        debounceTimer = setTimeout(fetchPreview, 200);
                    };
                    window.rulesTogglePreview = function() {
                        // 用 computed display 判断，避免初始 inline style 为空时首次点击反而隐藏
                        var cur = window.getComputedStyle(grid).display;
                        if (cur === 'none') {
                            grid.style.display = 'grid';
                            fetchPreview();
                        } else {
                            grid.style.display = 'none';
                        }
                    };
                })();
            </script>
